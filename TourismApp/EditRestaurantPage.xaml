<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TourismApp.EditRestaurantPage"
             Title="Quản lý nhà hàng"
             BackgroundColor="#F0F2F5">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15" BackgroundColor="#F5F5F5">
            <Border StrokeShape="RoundRectangle 20" HeightRequest="250" Margin="0,10" StrokeThickness="0" BackgroundColor="#F0F0F0">
                <Grid>
                    <Image x:Name="imgPreview" Aspect="AspectFill" Source="https://via.placeholder.com/400x250?text=Chưa+có+ảnh"/>
                    <Button Text="📷 Đổi ảnh" Clicked="OnSelectImageClicked" HorizontalOptions="End" VerticalOptions="End"
                            Margin="15" HeightRequest="40" BackgroundColor="#EEFFFFFF" TextColor="#2196F3"
                            CornerRadius="20" FontAttributes="Bold" BorderColor="#2196F3" BorderWidth="1"/>
                </Grid>
            </Border>

            <Frame CornerRadius="12" Padding="15" HasShadow="False" BorderColor="#DDD">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Thông tin cơ bản" FontAttributes="Bold" TextColor="#2196F3" FontSize="16"/>
                    <Label Text="Tên nhà hàng" FontSize="12" TextColor="Gray" Margin="0,0,0,-10"/>
                    <Entry x:Name="txtName" Placeholder="Nhập tên nhà hàng" TextColor="Black"/>
                    <Label Text="Số điện thoại" FontSize="12" TextColor="Gray" Margin="0,0,0,-10"/>
                    <Entry x:Name="txtPhone" Placeholder="Nhập số điện thoại" Keyboard="Telephone" TextColor="Black"/>
                    <Label Text="Mô tả" FontSize="12" TextColor="Gray" Margin="0,0,0,-10"/>
                    <Editor x:Name="txtDescription" Placeholder="Mô tả chi tiết..." HeightRequest="100" TextColor="Black"/>
                </VerticalStackLayout>
            </Frame>

            <Frame CornerRadius="12" Padding="15" HasShadow="False" BorderColor="#FF9800" BackgroundColor="#FFF9F0">
                <VerticalStackLayout Spacing="12">
                    <Label Text="🔊 Thuyết minh nhà hàng" FontAttributes="Bold" TextColor="#FF9800" FontSize="16"/>

                    <Label Text="Ngôn ngữ" FontSize="12" TextColor="Gray" Margin="0,0,0,-10"/>
                    <Picker x:Name="pickerLanguage" 
                Title="Chọn ngôn ngữ" 
                SelectedIndexChanged="OnLanguageChanged">
                        <Picker.Items>
                            <x:String>Tiếng Việt</x:String>
                            <x:String>English</x:String>
                        </Picker.Items>
                    </Picker>

                    <Label Text="Lời giới thiệu (Text)" FontSize="12" TextColor="Gray" Margin="0,0,0,-10"/>

                    <Editor x:Name="txtNarrationContent" 
                Placeholder="Nhập nội dung để máy tự động đọc..." 
                HeightRequest="100" 
                AutoSize="TextChanges"
                TextColor="Black"
                BackgroundColor="White"/>

                    <Grid ColumnDefinitions="*, Auto" ColumnSpacing="10">
                        <Label x:Name="lblAudioStatus" Text="Chưa chọn file audio (.mp3)" VerticalOptions="Center" TextColor="#555" FontSize="12" FontAttributes="Italic"/>
                        <Button Grid.Column="1" Text="🎵 CHỌN FILE" Clicked="OnSelectAudioClicked" 
                    BackgroundColor="#607D8B" TextColor="White" HeightRequest="40" CornerRadius="20" Padding="15,0"/>
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <Frame CornerRadius="12" Padding="15" HasShadow="False" BorderColor="#DDD">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Vị trí &amp; Bản đồ" FontAttributes="Bold" TextColor="#FF9800" FontSize="16"/>
                    <Label Text="Địa chỉ" FontSize="12" TextColor="Gray" Margin="0,0,0,-10"/>
                    <Entry x:Name="txtAddress" Placeholder="Nhập địa chỉ nhà hàng" TextColor="Black"/>
                    <Grid ColumnDefinitions="*, Auto" ColumnSpacing="10">
                        <Label x:Name="lblLocation" Text="Tọa độ: Đang lấy..." VerticalOptions="Center" TextColor="#555" FontSize="13"/>
                        <Button Grid.Column="1" Text="📍 LẤY GPS" Clicked="OnGetLocationClicked" 
                                BackgroundColor="#FF9800" TextColor="White" HeightRequest="40" CornerRadius="20" Padding="15,0"/>
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <Button Text="LƯU THAY ĐỔI" Clicked="OnSave" BackgroundColor="#2196F3" TextColor="White" 
                    FontAttributes="Bold" HeightRequest="55" CornerRadius="28" Margin="0,10,0,20"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>