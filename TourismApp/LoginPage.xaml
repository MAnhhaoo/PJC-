<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TourismApp.LoginPage"
             Shell.NavBarIsVisible="False"
             Shell.FlyoutBehavior="Disabled"
             BackgroundColor="White">

    <Grid>
        <ScrollView VerticalOptions="Center">
            <VerticalStackLayout Padding="30" Spacing="20">

                <Image Source="dotnet_bot.png" 
                       HeightRequest="100" 
                       HorizontalOptions="Center"
                       Margin="0,0,0,10"/>

                <Label x:Name="lblWelcome" Text="Chào mừng quay lại với phố ẩm thực !"
                       FontSize="26"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="#2C3E50"/>

              

                <Border Padding="0" StrokeShape="RoundRectangle 10" Stroke="#EDF2F7" StrokeThickness="1">
                    <Entry x:Name="txtEmail"
                           Placeholder="Email của bạn"
                           Keyboard="Email"
                           HeightRequest="50"
                           Margin="15,0"/>
                </Border>

                <Border Padding="0" StrokeShape="RoundRectangle 10" Stroke="#EDF2F7" StrokeThickness="1">
                    <Entry x:Name="txtPassword"
                           Placeholder="Mật khẩu"
                           IsPassword="True"
                           HeightRequest="50"
                           Margin="15,0"/>
                </Border>

                <Button x:Name="btnLogin"
                        Text="Đăng nhập ngay"
                        Clicked="OnLoginClicked"
                        BackgroundColor="#3498DB"
                        TextColor="White"
                        FontAttributes="Bold"
                        CornerRadius="10"
                        HeightRequest="55"/>

                <Button x:Name="btnGuest"
                        Text="👤 Tiếp tục với tư cách khách"
                        Clicked="OnGuestClicked"
                        BackgroundColor="Transparent"
                        TextColor="#7F8C8D"
                        FontAttributes="Bold"
                        CornerRadius="10"
                        HeightRequest="50"
                        BorderColor="#BDC3C7"
                        BorderWidth="1"/>

                <HorizontalStackLayout HorizontalOptions="Center" Spacing="5">
                    <Label x:Name="lblNoAccount" Text="Chưa có tài khoản?" VerticalOptions="Center"/>
                    <Button x:Name="btnRegisterNow" Text="Đăng ký ngay"
                            Clicked="OnGoToRegister"
                            BackgroundColor="Transparent"
                            TextColor="#3498DB"
                            FontAttributes="Bold"
                            Padding="0"/>
                </HorizontalStackLayout>

                <Label x:Name="lblServerSettings" Text="⚙ Cài đặt IP máy chủ"
                       TextColor="#95A5A6"
                       FontSize="12"
                       HorizontalOptions="Center"
                       TextDecorations="Underline">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnChangeServerIp"/>
                    </Label.GestureRecognizers>
                </Label>

            </VerticalStackLayout>
        </ScrollView>

        <ContentView x:Name="loadingOverlay" 
                     IsVisible="False" 
                     BackgroundColor="#80000000">
            <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="15">
                <ActivityIndicator IsRunning="True" Color="White" Scale="2"/>
                <Label x:Name="lblAuthenticating" Text="Đang xác thực..." TextColor="White" FontAttributes="Bold"/>
            </VerticalStackLayout>
        </ContentView>
    </Grid>
</ContentPage>