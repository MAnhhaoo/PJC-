<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TourismApp.EditProfilePage"
             Title="Chỉnh sửa hồ sơ">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <VerticalStackLayout HorizontalOptions="Center" Spacing="10">
                <Border StrokeShape="RoundRectangle 60"
                        HeightRequest="120" WidthRequest="120"
                        StrokeThickness="2" Stroke="Orange">
                    <Image x:Name="imgAvatar" Source="user_default.png" Aspect="AspectFill">
                        <Image.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnAvatarTapped"/>
                        </Image.GestureRecognizers>
                    </Image>
                </Border>
                <Label Text="Chạm để đổi ảnh" FontSize="12" HorizontalOptions="Center" TextColor="Gray"/>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="15">
                <Label Text="Email" FontAttributes="Bold" Margin="5,0"/>
                <Border StrokeShape="RoundRectangle 10" Padding="15,0" BackgroundColor="#EEEEEE" StrokeThickness="0">
                    <Entry x:Name="txtEmail" IsReadOnly="True" HeightRequest="50"/>
                </Border>

                <Label Text="Họ tên" FontAttributes="Bold" Margin="5,0"/>
                <Border StrokeShape="RoundRectangle 10" Padding="15,0" BackgroundColor="White" StrokeThickness="0">
                    <Entry x:Name="txtFullName" Placeholder="Họ và tên" HeightRequest="50"/>
                </Border>

                <Label Text="Số điện thoại" FontAttributes="Bold" Margin="5,0"/>
                <Border StrokeShape="RoundRectangle 10" Padding="15,0" BackgroundColor="White" StrokeThickness="0">
                    <Entry x:Name="txtPhone" Placeholder="Số điện thoại" Keyboard="Telephone" HeightRequest="50"/>
                </Border>

                <Label Text="Địa chỉ" FontAttributes="Bold" Margin="5,0"/>
                <Border StrokeShape="RoundRectangle 10" Padding="15,0" BackgroundColor="White" StrokeThickness="0">
                    <Entry x:Name="txtAddress" Placeholder="Địa chỉ" HeightRequest="50"/>
                </Border>
            </VerticalStackLayout>

            <Button Text="CẬP NHẬT HỒ SƠ" 
                    Clicked="OnSaveClicked" 
                    BackgroundColor="Orange" 
                    CornerRadius="25" 
                    FontAttributes="Bold"
                    HeightRequest="50" 
                    Margin="0,10,0,0"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>