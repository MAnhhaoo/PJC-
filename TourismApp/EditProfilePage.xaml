<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="TourismApp.EditProfilePage"
    Title="Chỉnh sửa hồ sơ"
    BackgroundColor="#F8F8F8">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <!-- Avatar -->
            <Frame HeightRequest="120"
                   WidthRequest="120"
                   CornerRadius="60"
                   HorizontalOptions="Center"
                   HasShadow="True"
                   BackgroundColor="White">

                <Image x:Name="imgAvatar"
                       Source="user_default.png"
                       Aspect="AspectFill"/>
            </Frame>

            <!-- Email (readonly) -->
            <Label Text="Email" FontAttributes="Bold"/>
            <Entry x:Name="txtEmail"
                   IsReadOnly="True"
                   BackgroundColor="#EEEEEE"/>

            <!-- Họ tên -->
            <Label Text="Họ tên" FontAttributes="Bold"/>
            <Entry x:Name="txtFullName"
                   Placeholder="Nhập họ tên"/>

            <!-- SĐT -->
            <Label Text="Số điện thoại" FontAttributes="Bold"/>
            <Entry x:Name="txtPhone"
                   Placeholder="Nhập số điện thoại"
                   Keyboard="Telephone"/>

            <!-- Địa chỉ -->
            <Label Text="Địa chỉ" FontAttributes="Bold"/>
            <Entry x:Name="txtAddress"
                   Placeholder="Nhập địa chỉ"/>

            <!-- Button -->
            <Button Text="Lưu thay đổi"
                    Clicked="OnSaveClicked"
                    BackgroundColor="Orange"
                    TextColor="White"
                    CornerRadius="10"
                    HeightRequest="50"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>