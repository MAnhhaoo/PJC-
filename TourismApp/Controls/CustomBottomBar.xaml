<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TourismApp.Controls.CustomBottomBar">

    <Grid ColumnDefinitions="*,*,80,*,*" HeightRequest="70" BackgroundColor="White" Padding="0">

        <!-- Top separator line -->
        <BoxView Grid.ColumnSpan="5" HeightRequest="0.5" VerticalOptions="Start" Color="#E0E0E0"/>

        <!-- Tab 0: Trang chủ -->
        <VerticalStackLayout Grid.Column="0" VerticalOptions="Center" HorizontalOptions="Center" Spacing="2">
            <Image x:Name="IconHome" Source="tab_home.png" HeightRequest="24" WidthRequest="24" HorizontalOptions="Center"/>
            <Label x:Name="LabelHome" Text="Trang chủ" FontSize="9" HorizontalTextAlignment="Center" TextColor="Gray"/>
            <VerticalStackLayout.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnHomeTapped"/>
            </VerticalStackLayout.GestureRecognizers>
        </VerticalStackLayout>

        <!-- Tab 1: Khám phá -->
        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" HorizontalOptions="Center" Spacing="2">
            <Image x:Name="IconExplore" Source="tab_explore.png" HeightRequest="24" WidthRequest="24" HorizontalOptions="Center"/>
            <Label x:Name="LabelExplore" Text="Khám phá" FontSize="9" HorizontalTextAlignment="Center" TextColor="Gray"/>
            <VerticalStackLayout.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnExploreTapped"/>
            </VerticalStackLayout.GestureRecognizers>
        </VerticalStackLayout>

        <!-- Floating center button: Quét QR -->
        <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" VerticalOptions="Start" Spacing="2"
                             Margin="0,-12,0,0">
            <Border StrokeShape="RoundRectangle 26"
                    HeightRequest="52" WidthRequest="52"
                    BackgroundColor="#FF5722"
                    Stroke="Transparent" StrokeThickness="0"
                    HorizontalOptions="Center">
                <Border.Shadow>
                    <Shadow Brush="#44000000" Offset="0,2" Radius="4" Opacity="0.2"/>
                </Border.Shadow>
                <Label Text="+" FontSize="26" TextColor="White"
                       HorizontalTextAlignment="Center" VerticalTextAlignment="Center"
                       Margin="0,-2,0,0"/>
            </Border>
            <Label Text="Quét QR" FontSize="9" HorizontalTextAlignment="Center" TextColor="Gray"/>
            <VerticalStackLayout.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnScanTapped"/>
            </VerticalStackLayout.GestureRecognizers>
        </VerticalStackLayout>

        <!-- Tab 2: Tour -->
        <VerticalStackLayout Grid.Column="3" VerticalOptions="Center" HorizontalOptions="Center" Spacing="2">
            <Image x:Name="IconTour" Source="tab_tour.png" HeightRequest="24" WidthRequest="24" HorizontalOptions="Center"/>
            <Label x:Name="LabelTour" Text="Tour" FontSize="9" HorizontalTextAlignment="Center" TextColor="Gray"/>
            <VerticalStackLayout.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnTourTapped"/>
            </VerticalStackLayout.GestureRecognizers>
        </VerticalStackLayout>

        <!-- Tab 3: Cài đặt -->
        <VerticalStackLayout Grid.Column="4" VerticalOptions="Center" HorizontalOptions="Center" Spacing="2">
            <Image x:Name="IconSettings" Source="tab_settings.png" HeightRequest="24" WidthRequest="24" HorizontalOptions="Center"/>
            <Label x:Name="LabelSettings" Text="Cài đặt" FontSize="9" HorizontalTextAlignment="Center" TextColor="Gray"/>
            <VerticalStackLayout.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnSettingsTapped"/>
            </VerticalStackLayout.GestureRecognizers>
        </VerticalStackLayout>

    </Grid>

</ContentView>
