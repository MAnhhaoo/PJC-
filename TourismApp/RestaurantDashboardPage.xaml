<?xml version="1.0" encoding="utf-8" ?>
<ContentPage 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="TourismApp.RestaurantDashboardPage"
    Title="Quản lý nhà hàng"
    BackgroundColor="#F5F5F5">

    <ScrollView>
        <VerticalStackLayout Padding="15" Spacing="12">

            <Border StrokeShape="RoundRectangle 16" HeightRequest="200" StrokeThickness="0">
                <Image Source="{Binding Image}" Aspect="AspectFill"/>
            </Border>

            <Label Text="{Binding Name}" FontSize="22" FontAttributes="Bold" TextColor="#333"/>
            <Label Text="{Binding Address}" TextColor="Gray" FontSize="14"/>
            <Label Text="{Binding Description}" LineBreakMode="WordWrap" FontSize="14" TextColor="#555"/>

            <Border StrokeShape="RoundRectangle 10" Padding="10" BackgroundColor="#FFF8E1" Stroke="#FFB300" StrokeThickness="1">
                <Label Text="{Binding PremiumText}" TextColor="#E65100" FontAttributes="Bold" FontSize="14"
                       HorizontalTextAlignment="Center"/>
            </Border>

            <!-- Management Buttons -->
            <Label Text="Quản lý" FontSize="18" FontAttributes="Bold" TextColor="#333" Margin="0,8,0,0"/>

            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="10">

                <Button Text="✏️ Chỉnh sửa nhà hàng"
                        BackgroundColor="#2196F3" TextColor="White" CornerRadius="12"
                        HeightRequest="50" FontSize="13"
                        Clicked="OnEditRestaurantClicked"/>

                <Button Grid.Column="1"
                        Text="🔊 Thuyết minh"
                        BackgroundColor="#FF9800" TextColor="White" CornerRadius="12"
                        HeightRequest="50" FontSize="13"
                        Clicked="OnManageNarrationsClicked"/>

                <Button Grid.Row="1"
                        Text="🍽 Danh sách món"
                        BackgroundColor="#4CAF50" TextColor="White" CornerRadius="12"
                        HeightRequest="50" FontSize="13"
                        Clicked="OnDishListClicked"/>

                <Button Grid.Row="1" Grid.Column="1"
                        Text="➕ Thêm món mới"
                        BackgroundColor="#009688" TextColor="White" CornerRadius="12"
                        HeightRequest="50" FontSize="13"
                        Clicked="OnAddDishClicked"/>

                <Button Grid.Row="2"
                        Text="📱 Mã QR nhà hàng"
                        BackgroundColor="#7B1FA2" TextColor="White" CornerRadius="12"
                        HeightRequest="50" FontSize="13"
                        Clicked="OnQRCodeClicked"/>

                <Button Grid.Row="2" Grid.Column="1"
                        Text="⭐ Nâng cấp Premium"
                        BackgroundColor="#FFB300" TextColor="White" CornerRadius="12"
                        HeightRequest="50" FontSize="13"
                        Clicked="OnUpgradeClicked"/>

                <Button Grid.Row="3" Grid.ColumnSpan="2"
                        Text="🚪 Đăng xuất"
                        BackgroundColor="#E53935" TextColor="White" CornerRadius="12"
                        HeightRequest="50" FontSize="14" FontAttributes="Bold"
                        Clicked="OnLogoutClicked"/>

            </Grid>

            <!-- Dish Preview -->
            <Label Text="Món ăn" FontSize="18" FontAttributes="Bold" TextColor="#333" Margin="0,8,0,0"/>

            <Border x:Name="frameDishLimit" StrokeShape="RoundRectangle 10" Padding="10" Stroke="#E0E0E0" StrokeThickness="1"
                   BackgroundColor="#E3F2FD" IsVisible="False">
                <Label x:Name="lblDishLimit" FontSize="13" TextColor="#1565C0" HorizontalTextAlignment="Center"/>
            </Border>

            <CollectionView ItemsSource="{Binding Dishes}" HeightRequest="200">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,4" Padding="10" StrokeShape="RoundRectangle 10"
                               BackgroundColor="White" Stroke="Transparent">
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,2" Radius="4" Opacity="0.3"/>
                            </Border.Shadow>
                            <Label Text="{Binding Name}" FontSize="15"/>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>