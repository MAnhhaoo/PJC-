<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="TourismApp.CustomerHomePage"
    Title="Khu phố ẩm thực Vĩnh Khánh"
    BackgroundColor="#F5F5F5">

    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <!-- Banner -->
        <Grid Grid.Row="0" HeightRequest="200">
            <Image Source="vinhkhanh_banner.jpg"
                   Aspect="AspectFill"/>

            <BoxView BackgroundColor="#66000000"/>

            <Label Text="KHU PHỐ ẨM THỰC VĨNH KHÁNH"
                   TextColor="White"
                   FontSize="24"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"/>
        </Grid>

        <!-- Description -->
        <Label Grid.Row="1"
               Text="Thiên đường ốc và hải sản nổi tiếng Quận 4, sôi động về đêm với hàng chục quán ăn hấp dẫn."
               Margin="15,10"
               TextColor="Gray"
               FontSize="14"/>

        <!-- Restaurant List -->
        <CollectionView
            x:Name="RestaurantList"
            Grid.Row="2"
            Margin="10">

            <CollectionView.ItemTemplate>

                <DataTemplate>

                    <Frame CornerRadius="16"
                           Margin="0,10"
                           Padding="0"
                           HasShadow="True"
                           BackgroundColor="White">

                        <!-- CLICK -->
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer
                                CommandParameter="{Binding RestaurantId}"
                                Tapped="OnRestaurantTapped"/>
                        </Frame.GestureRecognizers>

                        <VerticalStackLayout>

                            <!-- IMAGE -->
                            <Grid>

                                <Image Source="{Binding Image}"
                                       HeightRequest="180"
                                       Aspect="AspectFill"/>

                                <BoxView BackgroundColor="#66000000"/>

                                <Label Text="{Binding Name}"
                                       TextColor="White"
                                       FontSize="20"
                                       FontAttributes="Bold"
                                       VerticalOptions="End"
                                       Margin="10"/>

                            </Grid>

                            <!-- INFO -->
                            <VerticalStackLayout Padding="12" Spacing="6">

                                <Label Text="{Binding Address}"
                                       FontSize="13"
                                       TextColor="Gray"/>

                                <Label
                                    Text="{Binding Distance, StringFormat='📍 {0:F2} km'}"
                                    FontSize="12"
                                    TextColor="Gray"/>

                                <Label Text="{Binding Description}"
                                       FontSize="14"
                                       LineBreakMode="WordWrap"/>

                                <Label Text="⭐ Premium"
                                       IsVisible="{Binding IsPremium}"
                                       TextColor="OrangeRed"
                                       FontAttributes="Bold"/>

                            </VerticalStackLayout>
                            <Button
    Text="🗺 Xem bản đồ nhà hàng"
    Clicked="OnOpenMap"
    Margin="15"
    BackgroundColor="Orange"
    TextColor="White"
    CornerRadius="12"/>

                        </VerticalStackLayout>

                    </Frame>

                </DataTemplate>

            </CollectionView.ItemTemplate>

        </CollectionView>

        <!-- Profile Button -->
        <Button Grid.Row="3"
                Text="Hồ sơ"
                Clicked="OnProfileClicked"
                Margin="15"
                BackgroundColor="Orange"
                TextColor="White"
                CornerRadius="12"
                HeightRequest="50"/>

    </Grid>

</ContentPage>