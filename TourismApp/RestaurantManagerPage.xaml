<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TourismApp.RestaurantManagerPage"
             BackgroundColor="#F5F6FA"
             Title="Quản lý cửa hàng">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="25">

            <VerticalStackLayout Spacing="5">
                <Label Text="Xin chào, Chủ quán!" FontSize="14" TextColor="#7F8C8D"/>
                <Label Text="QUẢN TRỊ NHÀ HÀNG" FontSize="26" FontAttributes="Bold" TextColor="#2D3436"/>
            </VerticalStackLayout>

            <Grid ColumnDefinitions="*,*" 
      RowDefinitions="Auto,Auto,Auto" 
      ColumnSpacing="15" 
      RowSpacing="15">

                <Frame Grid.Row="0" Grid.Column="0" Padding="15" CornerRadius="15" HasShadow="True" BorderColor="Transparent">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="GoDashboard"/>
                    </Frame.GestureRecognizers>
                    <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                        <Label Text="📊" FontSize="35" HorizontalOptions="Center"/>
                        <Label Text="Thống kê" FontAttributes="Bold" HorizontalOptions="Center" TextColor="#34495E"/>
                    </VerticalStackLayout>
                </Frame>

                <Frame Grid.Row="0" Grid.Column="1" Padding="15" CornerRadius="15" HasShadow="True" BorderColor="Transparent">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="GoAddDish"/>
                    </Frame.GestureRecognizers>
                    <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                        <Label Text="➕" FontSize="35" HorizontalOptions="Center"/>
                        <Label Text="Thêm món" FontAttributes="Bold" HorizontalOptions="Center" TextColor="#34495E"/>
                    </VerticalStackLayout>
                </Frame>

                <Frame Grid.Row="1" Grid.Column="0" Padding="15" CornerRadius="15" HasShadow="True" BorderColor="Transparent">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="GoListDish"/>
                    </Frame.GestureRecognizers>
                    <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                        <Label Text="🍱" FontSize="35" HorizontalOptions="Center"/>
                        <Label Text="Thực đơn" FontAttributes="Bold" HorizontalOptions="Center" TextColor="#34495E"/>
                    </VerticalStackLayout>
                </Frame>

                <Frame Grid.Row="1" Grid.Column="1" Padding="15" CornerRadius="15" HasShadow="True" BorderColor="Transparent">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="GoEditRestaurant"/>
                    </Frame.GestureRecognizers>
                    <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                        <Label Text="📝" FontSize="35" HorizontalOptions="Center"/>
                        <Label Text="Cập nhật" FontAttributes="Bold" HorizontalOptions="Center" TextColor="#34495E"/>
                    </VerticalStackLayout>
                </Frame>

                <Frame Grid.Row="2" Grid.Column="0" Padding="15" CornerRadius="15" HasShadow="True" BorderColor="Transparent">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="GoMyAudios"/>
                    </Frame.GestureRecognizers>
                    <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                        <Label Text="🎧" FontSize="35" HorizontalOptions="Center"/>
                        <Label Text="Thuyết minh" FontAttributes="Bold" HorizontalOptions="Center" TextColor="#34495E"/>
                    </VerticalStackLayout>
                </Frame>

                <Frame Grid.Row="2" Grid.Column="1" Padding="15" CornerRadius="15" HasShadow="True" BorderColor="Transparent">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="GoUpgradePremium"/>
                    </Frame.GestureRecognizers>
                    <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                        <Label Text="💎" FontSize="35" HorizontalOptions="Center"/>
                        <Label Text="Nâng cấp" FontAttributes="Bold" HorizontalOptions="Center" TextColor="#34495E"/>
                    </VerticalStackLayout>
                </Frame>
                </Grid>

                <Frame BackgroundColor="#2196F3" CornerRadius="20" Padding="20" HasShadow="True" BorderColor="Transparent">
                <Grid ColumnDefinitions="*, Auto">
                    <VerticalStackLayout Spacing="5" VerticalOptions="Center">
                        <Label Text="Trạng thái hiện tại" TextColor="White" Opacity="0.8" FontSize="13"/>
                        <Label x:Name="lblStatusText" Text="Đang tải..." TextColor="White" FontAttributes="Bold" FontSize="20"/>
                    </VerticalStackLayout>

                    <Switch x:Name="swStatus" 
                            Grid.Column="1"
                            ThumbColor="White" 
                            OnColor="#4CAF50"
                            VerticalOptions="Center"
                            Toggled="OnStatusToggled"/>
                </Grid>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>