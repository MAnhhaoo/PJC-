<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TourismApp.RestaurantManagerPage"
             BackgroundColor="#F5F6FA"
             Title="Quản lý cửa hàng">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="25">

            <VerticalStackLayout Spacing="5">
                <Label Text="Xin chào, Chủ quán!" FontSize="14" TextColor="#7F8C8D"/>
                <Label Text="QUẢN TRỊ NHÀ HÀNG" FontSize="26" FontAttributes="Bold" TextColor="#2D3436"/>
            </VerticalStackLayout>

            <!-- NO RESTAURANT SECTION -->
            <VerticalStackLayout x:Name="noRestaurantSection" IsVisible="False" Spacing="20">
                <Frame BackgroundColor="#FFF3E0" CornerRadius="15" Padding="25" HasShadow="True" BorderColor="Transparent">
                    <VerticalStackLayout Spacing="15" HorizontalOptions="Center">
                        <Label Text="🏪" FontSize="60" HorizontalOptions="Center"/>
                        <Label Text="Bạn chưa đăng ký nhà hàng" FontSize="20" FontAttributes="Bold" HorizontalOptions="Center" TextColor="#E65100"/>
                        <Label Text="Hãy đăng ký nhà hàng để bắt đầu quản lý kinh doanh trên hệ thống" FontSize="14" TextColor="#7F8C8D" HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Frame>

                <Entry x:Name="txtCreateName" Placeholder="Tên nhà hàng *" FontSize="15"/>
                <Entry x:Name="txtCreateAddress" Placeholder="Địa chỉ *" FontSize="15"/>
                <Entry x:Name="txtCreatePhone" Placeholder="Số điện thoại" FontSize="15" Keyboard="Telephone"/>
                <Editor x:Name="txtCreateDescription" Placeholder="Mô tả nhà hàng" FontSize="15" HeightRequest="80"/>

                <!-- Plan Selection -->
                <Label Text="Chọn gói đăng ký" FontSize="18" FontAttributes="Bold" TextColor="#2D3436" Margin="0,10,0,0"/>

                <Frame x:Name="frameNormalPlan" CornerRadius="15" Padding="15" HasShadow="True"
                       BackgroundColor="#E3F2FD" BorderColor="#1565C0">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSelectNormalPlan"/>
                    </Frame.GestureRecognizers>
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Label Text="✅" FontSize="22" VerticalOptions="Center" x:Name="lblNormalCheck"/>
                        <VerticalStackLayout Grid.Column="1" Spacing="4" Margin="10,0">
                            <Label Text="🏪 Gói Thường" FontSize="16" FontAttributes="Bold" TextColor="#1565C0"/>
                            <Label Text="Giới hạn 8 món ăn" FontSize="13" TextColor="#666"/>
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="100.000đ" FontSize="16" FontAttributes="Bold"
                               TextColor="#E65100" VerticalOptions="Center"/>
                    </Grid>
                </Frame>

                <Frame x:Name="framePremiumPlan" CornerRadius="15" Padding="15" HasShadow="True"
                       BackgroundColor="White" BorderColor="#E0E0E0">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSelectPremiumPlan"/>
                    </Frame.GestureRecognizers>
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Label Text="⬜" FontSize="22" VerticalOptions="Center" x:Name="lblPremiumCheck"/>
                        <VerticalStackLayout Grid.Column="1" Spacing="4" Margin="10,0">
                            <Label Text="⭐ Gói Premium" FontSize="16" FontAttributes="Bold" TextColor="#FF8F00"/>
                            <Label Text="Không giới hạn món ăn • 1 năm" FontSize="13" TextColor="#666"/>
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="500.000đ" FontSize="16" FontAttributes="Bold"
                               TextColor="#E65100" VerticalOptions="Center"/>
                    </Grid>
                </Frame>

                <Button Text="🏪 Đăng ký nhà hàng"
                        BackgroundColor="#FF6D00"
                        TextColor="White"
                        FontAttributes="Bold"
                        CornerRadius="12"
                        HeightRequest="50"
                        Clicked="OnCreateRestaurantClicked"/>
            </VerticalStackLayout>

            <!-- MANAGEMENT SECTION -->
            <VerticalStackLayout x:Name="managementSection" IsVisible="False" Spacing="15">
                <Grid ColumnDefinitions="*,*" 
                      RowDefinitions="Auto,Auto,Auto" 
                      ColumnSpacing="15" 
                      RowSpacing="15">

                    <Frame Grid.Row="0" Grid.Column="0" Padding="15" CornerRadius="15" HasShadow="True" BorderColor="Transparent">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="GoDashboard"/>
                        </Frame.GestureRecognizers>
                        <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                            <Label Text="📊" FontSize="35" HorizontalOptions="Center"/>
                            <Label Text="Thống kê" FontAttributes="Bold" HorizontalOptions="Center" TextColor="#34495E"/>
                        </VerticalStackLayout>
                    </Frame>

                    <Frame Grid.Row="0" Grid.Column="1" Padding="15" CornerRadius="15" HasShadow="True" BorderColor="Transparent">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="GoAddDish"/>
                        </Frame.GestureRecognizers>
                        <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                            <Label Text="➕" FontSize="35" HorizontalOptions="Center"/>
                            <Label Text="Thêm món" FontAttributes="Bold" HorizontalOptions="Center" TextColor="#34495E"/>
                        </VerticalStackLayout>
                    </Frame>

                    <Frame Grid.Row="1" Grid.Column="0" Padding="15" CornerRadius="15" HasShadow="True" BorderColor="Transparent">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="GoListDish"/>
                        </Frame.GestureRecognizers>
                        <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                            <Label Text="🍱" FontSize="35" HorizontalOptions="Center"/>
                            <Label Text="Thực đơn" FontAttributes="Bold" HorizontalOptions="Center" TextColor="#34495E"/>
                        </VerticalStackLayout>
                    </Frame>

                    <Frame Grid.Row="1" Grid.Column="1" Padding="15" CornerRadius="15" HasShadow="True" BorderColor="Transparent">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="GoEditRestaurant"/>
                        </Frame.GestureRecognizers>
                        <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                            <Label Text="📝" FontSize="35" HorizontalOptions="Center"/>
                            <Label Text="Cập nhật" FontAttributes="Bold" HorizontalOptions="Center" TextColor="#34495E"/>
                        </VerticalStackLayout>
                    </Frame>

                    <Frame Grid.Row="2" Grid.Column="0" Padding="15" CornerRadius="15" HasShadow="True" BorderColor="Transparent">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="GoMyAudios"/>
                        </Frame.GestureRecognizers>
                        <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                            <Label Text="🎧" FontSize="35" HorizontalOptions="Center"/>
                            <Label Text="Thuyết minh" FontAttributes="Bold" HorizontalOptions="Center" TextColor="#34495E"/>
                        </VerticalStackLayout>
                    </Frame>

                    <Frame Grid.Row="2" Grid.Column="1" Padding="15" CornerRadius="15" HasShadow="True" BorderColor="Transparent">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="GoUpgradePremium"/>
                        </Frame.GestureRecognizers>
                        <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                            <Label Text="💎" FontSize="35" HorizontalOptions="Center"/>
                            <Label Text="Nâng cấp" FontAttributes="Bold" HorizontalOptions="Center" TextColor="#34495E"/>
                        </VerticalStackLayout>
                    </Frame>
                </Grid>

                <Frame BackgroundColor="#2196F3" CornerRadius="20" Padding="20" HasShadow="True" BorderColor="Transparent">
                    <Grid ColumnDefinitions="*, Auto">
                        <VerticalStackLayout Spacing="5" VerticalOptions="Center">
                            <Label Text="Trạng thái hiện tại" TextColor="White" Opacity="0.8" FontSize="13"/>
                            <Label x:Name="lblStatusText" Text="Đang tải..." TextColor="White" FontAttributes="Bold" FontSize="20"/>
                        </VerticalStackLayout>

                        <Switch x:Name="swStatus" 
                                Grid.Column="1"
                                ThumbColor="White" 
                                OnColor="#4CAF50"
                                VerticalOptions="Center"
                                Toggled="OnStatusToggled"/>
                    </Grid>
                </Frame>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>