<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TourismApp.RestaurantQRPage"
             Title="Mã QR nhà hàng"
             BackgroundColor="#F5F5F5">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16" HorizontalOptions="Center">

            <!-- Restaurant Name -->
            <Label x:Name="lblRestaurantName" 
                   FontSize="22" FontAttributes="Bold" TextColor="#333"
                   HorizontalTextAlignment="Center" Margin="0,10,0,0"/>

            <Label Text="Quét mã QR này để xem thông tin nhà hàng" 
                   FontSize="13" TextColor="Gray" HorizontalTextAlignment="Center"/>

            <!-- QR Code Image -->
            <Border StrokeShape="RoundRectangle 16" 
                    BackgroundColor="White" 
                    Padding="20" StrokeThickness="0"
                    HorizontalOptions="Center">
                <Border.Shadow>
                    <Shadow Brush="#22000000" Offset="0,2" Radius="8" Opacity="0.15"/>
                </Border.Shadow>
                <Image x:Name="imgQRCode" 
                       WidthRequest="260" HeightRequest="260"
                       Aspect="AspectFit"/>
            </Border>

            <!-- QR Content Info -->
            <Label x:Name="lblQRContent" 
                   FontSize="12" TextColor="Gray" 
                   HorizontalTextAlignment="Center"/>

            <!-- Action Buttons -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,10,0,0">
                <Button Text="💾 Lưu ảnh"
                        BackgroundColor="#4CAF50" TextColor="White"
                        CornerRadius="12" HeightRequest="50" FontSize="14" FontAttributes="Bold"
                        Clicked="OnSaveClicked"/>

                <Button Grid.Column="1" 
                        Text="📤 Chia sẻ"
                        BackgroundColor="#2196F3" TextColor="White"
                        CornerRadius="12" HeightRequest="50" FontSize="14" FontAttributes="Bold"
                        Clicked="OnShareClicked"/>
            </Grid>

            <!-- Instructions -->
            <Border StrokeShape="RoundRectangle 12" BackgroundColor="#FFF8E1" Padding="15" StrokeThickness="0" Margin="0,5,0,0">
                <VerticalStackLayout Spacing="6">
                    <Label Text="📋 Hướng dẫn sử dụng" FontSize="14" FontAttributes="Bold" TextColor="#E65100"/>
                    <Label Text="1. Nhấn 'Lưu ảnh' để tải QR về điện thoại" FontSize="13" TextColor="#555"/>
                    <Label Text="2. In ảnh QR ra giấy" FontSize="13" TextColor="#555"/>
                    <Label Text="3. Dán tại cửa hàng để khách quét" FontSize="13" TextColor="#555"/>
                    <Label Text="4. Hoặc nhấn 'Chia sẻ' để gửi qua Zalo, Email..." FontSize="13" TextColor="#555"/>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
