<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="TourismApp.RegisterPage"
    Title="Đăng ký">

    <VerticalStackLayout Padding="30" Spacing="15">

        <Label Text="ĐĂNG KÝ"
               FontSize="28"
               HorizontalOptions="Center"/>

        <Entry x:Name="txtFullName"
               Placeholder="Họ và tên"/>

        <Entry x:Name="txtEmail"
               Placeholder="Email"/>

        <Entry x:Name="txtPassword"
               Placeholder="Mật khẩu"
               IsPassword="True"/>

        <!-- 🔥 chọn role -->
        <Picker x:Name="rolePicker" Title="Chọn loại tài khoản">
            <Picker.Items>
                <x:String>User</x:String>
                <x:String>Restaurant</x:String>
            </Picker.Items>
        </Picker>

        <Button Text="Đăng ký"
                Clicked="OnRegisterClicked"/>

        <Button Text="Quay lại đăng nhập"
                Clicked="OnBackToLogin"/>

    </VerticalStackLayout>

</ContentPage>