@startuml Activity_06_OfflineSync
skinparam activity {
    BackgroundColor #ECEFF1
    BorderColor #37474F
    DiamondBackgroundColor #FFF9C4
    DiamondBorderColor #F57F17
}

title Sơ đồ Activity 6: Đồng bộ dữ liệu Offline

start

:Người dùng mở **SettingsPage**;
:Nhấn "Tải dữ liệu Offline";

:OfflineSyncService.SyncOfflineDataAsync();

:Gọi GET /api/restaurants;
:Nhận danh sách nhà hàng\n+ thuyết minh;

:Lưu vào SQLite cục bộ\n(PoiDbContext);

:Cập nhật thời gian\nđồng bộ cuối;

:Lưu "last_offline_sync"\nvào Preferences;

:Hiển thị "Đồng bộ thành công"\n+ Thời gian;

stop

@enduml
