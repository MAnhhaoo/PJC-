@startuml Activity_04_ManageRestaurant
skinparam activity {
    BackgroundColor #FFF3E0
    BorderColor #E65100
    DiamondBackgroundColor #FFF9C4
    DiamondBorderColor #F57F17
}

title Sơ đồ Activity 4: Quản lý Nhà hàng (Chủ nhà hàng)

start

:Chủ nhà hàng đăng nhập\n(Role = "Restaurant");

:Mở **RestaurantDashboardPage**;

:Gọi GET /api/restaurants/my;

if (Đã có nhà hàng?) then (Có)
    :Hiển thị thông tin nhà hàng\n+ Trạng thái (Approved/Pending);
    
    fork
        :Chỉnh sửa thông tin\n(**EditRestaurantPage**);
        :Gọi PUT /api/restaurants/update-my\n(multipart/form-data);
    fork again
        :Quản lý món ăn\n(**DishListPage**);
        :Xem danh sách món ăn;
        
        if (Thêm món mới?) then (Có)
            :Mở **AddDishPage**;
            :Nhập tên, chọn ảnh,\nghi âm audio, chọn ngôn ngữ;
            :POST /api/dishes (form-data);
            
            if (Premium hoặc < 8 món?) then (OK)
                :Lưu món ăn + thuyết minh;
            else (Quá giới hạn)
                :Hiển thị "Nâng cấp Premium";
            endif
        endif
    fork again
        :Nâng cấp Premium\n(**UpgradePremiumPage**);
        :Chuyển đến thanh toán;
        note right: Xem Activity 2
    fork again
        :Xem mã QR nhà hàng\n(**RestaurantQRPage**);
        :GET /api/restaurants/{id}/qrcode;
        :Hiển thị QR để\nchia sẻ / in;
    fork again
        :Nghe thuyết minh\n(**MyAudiosPage**);
        :Xem/Nghe audio\nđã tạo;
    end fork
    
else (Chưa có)
    :Hiển thị form đăng ký\nnhà hàng mới;
    :Nhập thông tin nhà hàng;
    :Chọn gói Thường / Premium;
    :Chuyển đến thanh toán;
    note right: Xem Activity 2
endif

stop

@enduml


