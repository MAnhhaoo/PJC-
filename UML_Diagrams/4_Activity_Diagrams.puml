@startuml Activity_05_ChangeLanguage
skinparam activity {
    BackgroundColor #E0F7FA
    BorderColor #00695C
    DiamondBackgroundColor #FFF9C4
    DiamondBorderColor #F57F17
}

title Sơ đồ Activity 5: Đổi ngôn ngữ + Dịch thuật tự động

start

:Người dùng mở **CustomerHomePage**;

:Chọn ngôn ngữ từ Picker\n(VI / EN / JA / FR / KO / ZH / TH);

:LanguageService.SetLanguage(code);
:Lưu vào Preferences;

:Cập nhật tất cả Label\ntrên giao diện (i18n);

if (Ngôn ngữ != "vi"?) then (Khác tiếng Việt)
    :Gọi TranslationService\n.TranslateRestaurantsAsync();
    
    repeat :Dịch từng nhà hàng;
        :Kiểm tra cache\n(ConcurrentDictionary);
        
        if (Có trong cache?) then (Có)
            :Dùng bản dịch từ cache;
        else (Không)
            :Gọi MyMemory API\nhttps://api.mymemory.translated.net;
            :Lưu kết quả vào cache\n+ Preferences;
        endif
    repeat while (Còn nhà hàng chưa dịch?)
    
    :Cập nhật danh sách\nnhà hàng đã dịch;
else (Tiếng Việt)
    :Hiển thị dữ liệu gốc;
endif

:Giao diện đã được\ncập nhật ngôn ngữ mới;

stop

@enduml


