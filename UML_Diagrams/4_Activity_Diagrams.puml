@startuml Activity_01_Login
skinparam activity {
    BackgroundColor #E3F2FD
    BorderColor #1565C0
    DiamondBackgroundColor #FFF9C4
    DiamondBorderColor #F57F17
}

title Sơ đồ Activity 1: Quy trình Đăng nhập

start

:Người dùng mở ứng dụng;

if (Đã có token trong SecureStorage?) then (Có)
    :Lấy token từ SecureStorage;
    :Gọi API GetMe() kiểm tra token;
    
    if (Token hợp lệ?) then (Có)
        if (Role == "Restaurant"?) then (Có)
            :Chuyển đến **RestaurantDashboardPage**;
        else (Không)
            :Chuyển đến **CustomerHomePage**;
        endif
        stop
    else (Không / Hết hạn)
        :Xóa token cũ;
    endif
endif

:Hiển thị **LoginPage**;
:Người dùng nhập Email + Mật khẩu;
:Nhấn nút "Đăng nhập";

:Gọi API POST /api/users/app-login;

if (Email tồn tại?) then (Có)
    :BCrypt.Verify(password, hash);
    
    if (Mật khẩu đúng?) then (Đúng)
        if (Tài khoản Active?) then (Active)
            :Tạo JWT Token;
            :Lưu token vào SecureStorage;
            :Lưu role, fullName vào Preferences;
            
            if (Role == "Restaurant"?) then (Có)
                :Chuyển đến\n**RestaurantDashboardPage**;
            else (Không)
                :Chuyển đến\n**CustomerHomePage**;
            endif
        else (Bị khóa)
            :Hiển thị "Tài khoản đã bị khóa";
        endif
    else (Sai)
        :Hiển thị "Sai email hoặc mật khẩu";
    endif
else (Không)
    :Hiển thị "Sai email hoặc mật khẩu";
endif

stop

@enduml


' ================================================================


@startuml Activity_02_Payment
skinparam activity {
    BackgroundColor #FFEBEE
    BorderColor #D32F2F
    DiamondBackgroundColor #FFF9C4
    DiamondBorderColor #F57F17
}

title Sơ đồ Activity 2: Quy trình Thanh toán (Tour / Nhà hàng)

start

:Người dùng chọn Tour\nhoặc Đăng ký nhà hàng;

:Mở **PaymentPage**\n(TourPaymentPage / RestaurantPaymentPage);

:Gọi API tạo Payment\n(POST /api/payments/purchase-tour\nhoặc register-restaurant);

if (Đã mua/đăng ký rồi?) then (Đã mua)
    :Hiển thị "Bạn đã mua rồi";
    stop
else (Chưa)
endif

if (Có Payment Pending?) then (Có)
    :Dùng lại Payment cũ;
else (Chưa)
    :Tạo Payment mới\n(Status = "Pending")\nTransactionId = "TPA{PaymentId}";
endif

:Tạo URL VietQR:\nhttps://img.vietqr.io/image/\n{bankId}-{accountNo}\n?amount=X&addInfo=TPA{id};

:Tải và hiển thị **mã QR**\ntrên màn hình;

:Hiển thị thông tin chuyển khoản:\nNgân hàng, STK, Số tiền,\nNội dung CK;

fork
    :Bắt đầu **Polling**\n(mỗi 3 giây);
    
    repeat
        :Gọi API check-tour/{id}\nhoặc check-restaurant/{id};
        
        if (isPurchased / isPaid == true?) then (Đã thanh toán)
            :Dừng Polling;
            :Hiển thị ✅ "Thành công!";
            :Quay về trang trước;
            stop
        else (Chưa)
            :Đợi 3 giây;
        endif
    repeat while (Chưa thanh toán)

fork again
    :Người dùng quét QR\nbằng app ngân hàng;
    :Chuyển khoản đúng\nsố tiền + nội dung CK;
    
    :Ngân hàng thông báo\ncho **SePay**;
    
    :SePay gọi **Webhook**\nPOST /api/payments/webhook\n{ content: "TPA123",\ntransferAmount: X };
    
    :API tìm Payment theo\nregex TPA(\\d+);
    
    if (Số tiền đủ?) then (Đủ)
        :Payment.Status = "Success";
        
        if (PaymentType?) then
            if (TourPurchase) then (Tour)
                :Tour đã mở khóa;
            elseif (RestaurantRegistration) then (Nhà hàng thường)
                :Restaurant.IsApproved = true;
            elseif (RestaurantRegistrationPremium) then (Nhà hàng Premium)
                :Restaurant.IsApproved = true\nRestaurant.IsPremium = true\nPremiumExpireDate = +1 năm;
            endif
        endif
    else (Không đủ)
        :Từ chối "Amount insufficient";
    endif

end fork

stop

@enduml


