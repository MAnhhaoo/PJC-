@startuml Activity_03_GPSTour
skinparam activity {
    BackgroundColor #F3E5F5
    BorderColor #6A1B9A
    DiamondBackgroundColor #FFF9C4
    DiamondBorderColor #F57F17
}

title Sơ đồ Activity 3: Đi Tour GPS + Thuyết minh tự động

start

:Người dùng chọn Tour\ntừ **TourListPage**;

if (Tour có giá > 0?) then (Trả phí)
    if (Đã mua tour?) then (Đã mua)
    else (Chưa)
        :Chuyển đến **TourPaymentPage**;
        :Thanh toán tour;
        note right: Xem Activity 2
    endif
else (Miễn phí)
endif

:Mở **TourDetailPage**;
:Hiển thị thông tin Tour\n+ Danh sách POI;

:Nhấn "Bắt đầu Tour";
:Mở **POIMapPage**;

:Hiển thị bản đồ\nvới các Pin nhà hàng;

:StartLocationUpdates();
:Tạo CancellationTokenSource;
:Tạo SessionId cho Analytics;

repeat
    :Lấy vị trí GPS hiện tại;
    :Cập nhật vị trí trên bản đồ;
    
    :Gửi TrackPoint\nPOST /api/analytics/track-point;
    
    :Tính khoảng cách tới\nmỗi POI (nhà hàng);
    
    if (Có POI nào trong bán kính\nphát hiện? (mặc định 5m)) then (Có)
        if (Đã phát cho POI này\ntrong phiên?) then (Đã phát)
        else (Chưa phát)
            :Lấy ngôn ngữ hiện tại\ntừ LanguageService;
            
            :Tìm Narration theo\nlanguageCode;
            
            if (Có audio file\ntrên server?) then (Có)
                :Tải audio từ server\nGET /audios/{file};
                
                if (Tải thành công?) then (OK)
                    :Phát audio bằng\nAudioManager;
                else (Lỗi 404)
                    :Dùng TextToSpeech\nđọc textContent;
                endif
            else (Không có audio)
                :Dùng TextToSpeech\nđọc textContent;
            endif
            
            :Gửi NarrationPlayLog\nPOST /api/analytics/narration-play;
            
            :Đánh dấu đã phát\ncho POI này;
        endif
    else (Không)
    endif
    
    :Đợi 3 giây;
    
repeat while (CancellationToken\nchưa bị Cancel?)

:StopLocationUpdates();

stop

@enduml


