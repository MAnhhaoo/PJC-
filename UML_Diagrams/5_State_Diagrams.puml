@startuml State_04_Tour
skinparam state {
    BackgroundColor #F3E5F5
    BorderColor #6A1B9A
}

title Sơ đồ State 4: Trạng thái Tour Du lịch

[*] --> TourActive

state TourActive #E8F5E9 {
    TourActive : IsActive = true
    TourActive : Hiển thị trên app

    state TourMienPhi #C8E6C9 {
        TourMienPhi : Price = 0
        TourMienPhi : Ai cũng có thể đi
    }
    
    state TourTraPhi #B3E5FC {
        TourTraPhi : Price > 0
        TourTraPhi : Cần mua để mở khóa
    }
}

state TourInactive #ECEFF1 {
    TourInactive : IsActive = false
    TourInactive : Không hiển thị
    TourInactive : Admin đã tắt
}

TourActive --> TourInactive : Admin tắt Tour\n(IsActive = false)
TourInactive --> TourActive : Admin bật lại\n(IsActive = true)

' ===== Trạng thái User với Tour =====

state "Trạng thái người dùng\nvới Tour trả phí" as UserTourState {
    state ChuaMua #FFF9C4 {
        ChuaMua : Chưa thanh toán
        ChuaMua : Chỉ xem thông tin
    }
    
    state DangThanhToan #FFE0B2 {
        DangThanhToan : Payment Pending
        DangThanhToan : Đang hiện QR
    }
    
    state DaMua #C8E6C9 {
        DaMua : Payment Success
        DaMua : Có thể đi Tour
    }
    
    state DangDiTour #B3E5FC {
        DangDiTour : GPS đang theo dõi
        DangDiTour : Auto-play thuyết minh
        DangDiTour : Gửi TrackPoint
    }
    
    ChuaMua --> DangThanhToan : Nhấn "Mua Tour"
    DangThanhToan --> DaMua : SePay xác nhận\nthanh toán
    DangThanhToan --> ChuaMua : Hủy thanh toán\n(Thoát trang)
    DaMua --> DangDiTour : Nhấn "Bắt đầu Tour"
    DangDiTour --> DaMua : Dừng Tour\n(StopLocationUpdates)
}

@enduml


