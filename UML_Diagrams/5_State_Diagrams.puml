@startuml State_03_User
skinparam state {
    BackgroundColor #E3F2FD
    BorderColor #1565C0
}

title Sơ đồ State 3: Trạng thái Người dùng (User)

[*] --> ChuaDangKy

state ChuaDangKy #ECEFF1 {
    ChuaDangKy : Chưa có tài khoản
    ChuaDangKy : Có thể dùng chế độ\nẩn danh (Guest)
}

state Active #C8E6C9 {

    state UserThuong #E8F5E9 {
        UserThuong : UserLevel = 0
        UserThuong : Chức năng cơ bản
    }
    
    state UserVIP #B3E5FC {
        UserVIP : UserLevel = 1
        UserVIP : Đã nâng cấp VIP
        UserVIP : Chức năng nâng cao
    }
    
    UserThuong --> UserVIP : Nâng cấp VIP\n(UserUpgrade Payment)
}

state Banned #FFCDD2 {
    Banned : Status = "Banned"
    Banned : Không thể đăng nhập
    Banned : Admin đã khóa
}

ChuaDangKy --> Active : Đăng ký tài khoản\nPOST /api/users/register

Active --> Banned : Admin khóa\nToggleStatus()

Banned --> Active : Admin mở khóa\nToggleStatus()

@enduml


