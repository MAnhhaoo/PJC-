@startuml State_01_Payment
skinparam state {
    BackgroundColor #FFFDE7
    BorderColor #F57F17
}

title Sơ đồ State 1: Trạng thái Thanh toán (Payment)

[*] --> Pending : Người dùng tạo\nyêu cầu thanh toán

state Pending #FFF9C4 {
    Pending : Đang chờ chuyển khoản
    Pending : TransactionId = "TPA{id}"
    Pending : App đang Polling mỗi 3s
}

state Success #C8E6C9 {
    Success : Đã thanh toán thành công
    Success : Xác nhận qua SePay Webhook
    Success : hoặc Admin xác nhận thủ công
}

state Failed #FFCDD2 {
    Failed : Thanh toán thất bại
    Failed : Số tiền không đủ
}

state Cancelled #ECEFF1 {
    Cancelled : Người dùng hủy
    Cancelled : Thoát trang thanh toán
}

Pending --> Success : SePay Webhook\nxác nhận\n(amount >= required)
Pending --> Success : Admin gọi\nPOST /confirm/{id}
Pending --> Failed : Số tiền\nkhông đủ
Pending --> Cancelled : Người dùng\nthoát trang\n(OnDisappearing)

Success --> [*]
Failed --> [*]
Cancelled --> [*]

note right of Success
  Tùy PaymentType:
  - TourPurchase → Mở khóa tour
  - RestaurantRegistration → IsApproved = true
  - RestaurantRegistrationPremium → IsApproved + IsPremium
  - RestaurantPremium → IsPremium = true
  - UserUpgrade → UserLevel = 1
end note

@enduml


' ================================================================


@startuml State_02_Restaurant
skinparam state {
    BackgroundColor #E8F5E9
    BorderColor #2E7D32
}

title Sơ đồ State 2: Trạng thái Nhà hàng (Restaurant)

[*] --> ChuaDangKy

state ChuaDangKy #ECEFF1 {
    ChuaDangKy : Chủ nhà hàng chưa\nđăng ký nhà hàng
}

state ChoDuyet #FFF9C4 {
    ChoDuyet : IsApproved = false
    ChoDuyet : Đã tạo Restaurant
    ChoDuyet : Đang chờ thanh toán
}

state HoatDongThuong #C8E6C9 {
    HoatDongThuong : IsApproved = true
    HoatDongThuong : IsPremium = false
    HoatDongThuong : Giới hạn 8 món ăn
    HoatDongThuong : Hiển thị trên app
}

state HoatDongPremium #B3E5FC {
    HoatDongPremium : IsApproved = true
    HoatDongPremium : IsPremium = true
    HoatDongPremium : Không giới hạn món
    HoatDongPremium : Ưu tiên hiển thị
}

state HetHanPremium #FFE0B2 {
    HetHanPremium : PremiumExpireDate < now
    HetHanPremium : Tự động hạ về Thường
}

ChuaDangKy --> ChoDuyet : Chủ nhà hàng\nnhấn "Đăng ký"\n+ Tạo Restaurant

ChoDuyet --> HoatDongThuong : Thanh toán gói Thường\nthành công\n(SePay Webhook)

ChoDuyet --> HoatDongPremium : Thanh toán gói Premium\nthành công\n(SePay Webhook)

HoatDongThuong --> HoatDongPremium : Nâng cấp Premium\n+ Thanh toán thành công

HoatDongPremium --> HetHanPremium : PremiumExpireDate\nhết hạn

HetHanPremium --> HoatDongThuong : Tự động hạ\nvề gói Thường

HetHanPremium --> HoatDongPremium : Gia hạn Premium\n+ Thanh toán

ChoDuyet --> ChuaDangKy : Hủy đăng ký\n(CancelRestaurantPayment)\nXóa Restaurant + Payment

@enduml


