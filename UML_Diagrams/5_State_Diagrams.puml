@startuml State_05_Narration
skinparam state {
    BackgroundColor #E0F2F1
    BorderColor #00695C
}

title Sơ đồ State 5: Trạng thái phát Thuyết minh (Narration)

[*] --> ChuaPhat

state ChuaPhat #ECEFF1 {
    ChuaPhat : Người dùng chưa\nđến gần POI
    ChuaPhat : hoặc chưa nhấn phát
}

state DangTimNarration #FFF9C4 {
    DangTimNarration : Tìm Narration theo\nlanguageCode hiện tại
}

state DangTaiAudio #FFE0B2 {
    DangTaiAudio : GET /audios/{file}
    DangTaiAudio : Tải file audio từ server
}

state DangPhatAudio #C8E6C9 {
    DangPhatAudio : AudioManager đang phát
    DangPhatAudio : file audio
}

state DangPhatTTS #B3E5FC {
    DangPhatTTS : TextToSpeech.SpeakAsync()
    DangPhatTTS : Đọc textContent
}

state DaPhat #E8EAF6 {
    DaPhat : Đã phát xong
    DaPhat : Log NarrationPlayLog
    DaPhat : Đánh dấu đã phát
}

state Loi #FFCDD2 {
    Loi : Không có Narration
    Loi : hoặc lỗi phát
}

ChuaPhat --> DangTimNarration : Người dùng đến gần POI\n(khoảng cách <= bán kính)\nhoặc nhấn nút phát

DangTimNarration --> DangTaiAudio : Tìm thấy Narration\ncó AudioUrl

DangTimNarration --> DangPhatTTS : Tìm thấy Narration\nchỉ có TextContent\n(không có audio)

DangTimNarration --> Loi : Không tìm thấy\nNarration cho ngôn ngữ này

DangTaiAudio --> DangPhatAudio : Tải audio\nthành công (200 OK)

DangTaiAudio --> DangPhatTTS : Lỗi tải audio (404)\nFallback sang TTS

DangPhatAudio --> DaPhat : Phát xong

DangPhatTTS --> DaPhat : Đọc xong

DaPhat --> ChuaPhat : Chuyển sang\nPOI tiếp theo

Loi --> ChuaPhat : Bỏ qua POI này

@enduml
