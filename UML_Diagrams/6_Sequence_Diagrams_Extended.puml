@startuml Sequence_10_CreateTTS
skinparam sequence {
    ArrowColor #1565C0
    LifeLineBorderColor #333
    ParticipantBackgroundColor #E3F2FD
    ParticipantBorderColor #1565C0
}

title Sơ đồ Sequence 10: Tạo file TTS thuyết minh (Text-to-Speech)

actor "Admin / Chủ nhà hàng" as User
participant "ManageNarrations\n(Blazor)" as UI
participant "NarrationsController\n(API)" as API
participant "MyMemory API\n(Dịch thuật)" as Translate
participant "Google TTS\n(Text-to-Speech)" as TTS
database "SQL Server" as DB
database "File System\n(audios/)" as FS

User -> UI : Nhập nội dung thuyết minh\n+ Chọn ngôn ngữ đích
activate UI

UI -> API : POST /api/narrations/create-translated-multi\n{ textContent, languageCodes[], restaurantId }
activate API

API -> DB : Lấy Languages theo codes
activate DB
DB --> API : Danh sách Language entities
deactivate DB

loop Với mỗi languageCode trong danh sách
    alt languageCode != "vi" (không phải tiếng Việt)
        API -> Translate : GET /get?q={text}&langpair=vi|{code}
        activate Translate
        Translate --> API : { translatedText }
        deactivate Translate
        API -> API : textForTts = translatedText
    else languageCode == "vi"
        API -> API : textForTts = originalText
    end

    API -> TTS : GET /translate_tts?q={textForTts}&tl={code}&client=tw-ob
    activate TTS
    TTS --> API : audioBytes (MP3)
    deactivate TTS

    API -> FS : WriteAllBytesAsync(\n  "res_{restaurantId}_{code}_{guid}.mp3",\n  audioBytes)
    activate FS
    FS --> API : File saved
    deactivate FS

    API -> DB : INSERT Narration {\n  RestaurantId, LanguageId,\n  TextContent, AudioUrl }
    activate DB
    DB --> API : OK
    deactivate DB
end

API --> UI : 200 OK { created: N }
deactivate API

UI --> User : Hiển thị "Tạo thành công N thuyết minh"
deactivate UI

@enduml


