}

title Sơ đồ Sequence 19: Thuyết minh tự động (Auto Narration khi chỉnh sửa nhà hàng)

actor "Chủ nhà hàng" as Owner
participant "EditRestaurantPage\n(MAUI)" as UI
participant "HttpClient\n(MAUI)" as HTTP
participant "RestaurantsController\n(API)" as API
participant "MyMemory API\n(Dịch thuật)" as Translate
participant "Google TTS\n(Text-to-Speech)" as TTS
database "SQL Server" as DB
database "File System\n(audios/)" as FS

Owner -> UI : Cập nhật nhà hàng:\nNhập nội dung thuyết minh\nChọn nhiều ngôn ngữ
activate UI

UI -> HTTP : PUT /api/restaurants/update-my\n[multipart/form-data]\nname, address, description,\nlanguageIds[], textContents[],\nimageFile?
activate HTTP

HTTP -> API : UpdateMyRestaurant(form data)
activate API

API -> DB : SELECT Restaurant\nJOIN Narrations\nWHERE OwnerId = {userId}
activate DB
DB --> API : Restaurant + Narrations hiện tại
deactivate DB

API -> API : Cập nhật thông tin cơ bản:\nName, Address, Description, Phone

alt Có imageFile upload
    API -> FS : Lưu ảnh mới\n→ images/{guid}.ext
end

loop Với mỗi languageId[i]
    API -> DB : Lấy Language.Code\ntừ languageId
    
    alt languageCode != "vi" && có textContent
        API -> Translate : GET /get?q={text}\n&langpair=vi|{langCode}
        activate Translate
        Translate --> API : { translatedText }
        deactivate Translate
        API -> API : finalText = translatedText
    else
        API -> API : finalText = originalText
    end

    alt Có audioFile_{i} upload
        API -> FS : Lưu audio upload\n→ audios/{guid}.ext
        API -> API : audioUrl = {fileName}
    else Không có file upload → Tạo TTS tự động
        API -> TTS : GET /translate_tts?q={finalText}\n&tl={langCode}&client=tw-ob
        activate TTS
        TTS --> API : audioBytes (MP3)
        deactivate TTS
        API -> FS : WriteAllBytesAsync(\n  "res_{restaurantId}_{code}_{guid}.mp3")
        API -> API : audioUrl = ttsFileName
    end

    alt Narration đã tồn tại cho ngôn ngữ này
        API -> DB : UPDATE Narration SET\n  TextContent, AudioUrl
    else Narration chưa tồn tại
        API -> DB : INSERT Narration {\n  RestaurantId, LanguageId,\n  TextContent, AudioUrl }
    end
end

API -> DB : SaveChanges()
API --> HTTP : 200 OK { restaurant }
deactivate API
HTTP --> UI : Kết quả cập nhật
deactivate HTTP
UI --> Owner : "Cập nhật nhà hàng\nthành công"
deactivate UI

@enduml

