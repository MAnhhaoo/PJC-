@startuml Sequence_04_TourPayment
skinparam sequence {
    ArrowColor #D32F2F
    ParticipantBackgroundColor #FFEBEE
    ParticipantBorderColor #D32F2F
}

title Sơ đồ Sequence 4: Thanh toán mua Tour qua VietQR + SePay

actor "Người dùng" as User
participant "TourPaymentPage\n(MAUI)" as TP
participant "HttpClient" as HTTP
participant "PaymentsController\n(API)" as API
participant "VietQR\n(Bên ngoài)" as VQR
participant "SePay\n(Webhook)" as SePay
database "SQL Server" as DB

User -> TP : Mở trang thanh toán\n(tourId, tourName, price)
activate TP

TP -> TP : OnAppearing()
TP -> HTTP : POST /api/payments/purchase-tour\n{ tourId, paymentMethod: "QR" }
activate HTTP

HTTP -> API : PurchaseTour(request)
activate API

API -> DB : Kiểm tra đã mua chưa?
activate DB
DB --> API : Chưa mua
deactivate DB

API -> DB : Tạo Payment (Status: "Pending")
activate DB
DB --> API : PaymentId
deactivate DB

API -> API : TransactionId = "TPA{PaymentId}"
API --> HTTP : { paymentId, referenceCode, amount }
deactivate API

HTTP --> TP : Response JSON
deactivate HTTP

TP -> TP : Tạo URL VietQR:\nimg.vietqr.io/image/{bank}-{account}\n?amount=X&addInfo=TPA{id}
TP -> VQR : Tải hình QR code
VQR --> TP : Hình ảnh QR PNG

TP --> User : Hiển thị mã QR +\nthông tin chuyển khoản

TP -> TP : StartPolling(token)

loop Mỗi 3 giây
    TP -> HTTP : GET /api/payments/check-tour/{tourId}
    HTTP -> API : CheckTourAccess(tourId)
    API -> DB : Kiểm tra Payment.Status
    DB --> API : { isPurchased: false }
    API --> HTTP : { isPurchased: false }
    HTTP --> TP : Chưa thanh toán
end

User -> User : Quét QR bằng app ngân hàng\n→ Chuyển khoản

SePay -> API : POST /api/payments/webhook\n{ content: "TPA123", transferAmount: X }
activate API
API -> API : Regex.Match("TPA(\\d+)")
API -> DB : Tìm Payment theo PaymentId
API -> API : Kiểm tra amount >= payment.Amount
API -> DB : Payment.Status = "Success"
API --> SePay : { success: true }
deactivate API

TP -> HTTP : GET /api/payments/check-tour/{tourId}
HTTP -> API : CheckTourAccess(tourId)
API -> DB : Payment.Status == "Success"
DB --> API : { isPurchased: true }
API --> HTTP : { isPurchased: true }
HTTP --> TP : Đã thanh toán!

TP --> User : ✅ Hiển thị "Thanh toán thành công!"
TP -> TP : Shell.GoToAsync("..")

deactivate TP

@enduml


' ================================================================


@startuml Sequence_05_GPSTour
skinparam sequence {
    ArrowColor #6A1B9A
    ParticipantBackgroundColor #F3E5F5
    ParticipantBorderColor #6A1B9A
}

title Sơ đồ Sequence 5: Đi Tour với GPS và phát thuyết minh tự động

actor "Người dùng" as User
participant "POIMapPage\n(MAUI)" as Map
participant "GpsService" as GPS
participant "LanguageService" as LS
participant "AnalyticsService" as AS
participant "HttpClient" as HTTP
participant "API Server" as API

User -> Map : Bắt đầu đi Tour
activate Map

Map -> Map : StartLocationUpdates()
Map -> GPS : GetCurrentLocation()
GPS --> Map : (latitude, longitude)

Map -> Map : Hiển thị vị trí trên bản đồ\n+ Các Pin nhà hàng (POI)

loop Mỗi 3 giây (Background Task)
    Map -> GPS : GetCurrentLocation()
    GPS --> Map : (lat, lng)

    Map -> Map : CalculateDistance(\ncurrentPos, eachPOI)

    alt Khoảng cách <= bán kính phát hiện (mặc định 5m)
        Map -> LS : GetCurrentLanguage()
        LS --> Map : languageCode

        Map -> Map : Tìm Narration theo\nlanguageCode

        alt Có Audio trên server
            Map -> HTTP : GET /audios/{fileName}
            HTTP --> Map : Audio stream
            Map -> Map : AudioManager.Play(stream)
        else Không có Audio (404)
            Map -> Map : TextToSpeech.SpeakAsync(\ntextContent, language)
        end

        Map -> AS : LogNarrationPlayAsync(\nrestaurantId, tourId, lat, lng)
        AS -> HTTP : POST /api/analytics/narration-play
        HTTP -> API : Lưu NarrationPlayLog
    end

    Map -> AS : LogTrackPointAsync(\ntourId, sessionId, lat, lng)
    AS -> HTTP : POST /api/analytics/track-point
    HTTP -> API : Lưu TourTrackPoint
end

User -> Map : Dừng Tour
Map -> Map : StopLocationUpdates()
Map -> Map : CancellationTokenSource.Cancel()

deactivate Map

@enduml


' ================================================================


@startuml Sequence_06_RegisterRestaurant
skinparam sequence {
    ArrowColor #FF6F00
    ParticipantBackgroundColor #FFF8E1
    ParticipantBorderColor #FF6F00
}

title Sơ đồ Sequence 6: Đăng ký nhà hàng + Thanh toán

actor "Chủ nhà hàng" as Owner
participant "RestaurantDashboardPage\n(MAUI)" as Dash
participant "HttpClient" as HTTP
participant "RestaurantsController\n(API)" as RestAPI
participant "RestaurantPaymentPage\n(MAUI)" as Pay
participant "PaymentsController\n(API)" as PayAPI
participant "VietQR" as VQR
participant "SePay" as SePay
database "SQL Server" as DB

Owner -> Dash : Nhấn "Đăng ký nhà hàng"
activate Dash

Dash -> Dash : Nhập thông tin:\nTên, Địa chỉ, SĐT, Mô tả\nChọn vị trí trên bản đồ

Dash -> HTTP : POST /api/restaurants\n{ name, address, ... }
activate HTTP

HTTP -> RestAPI : CreateRestaurant(dto)
RestAPI -> DB : Thêm Restaurant\n(IsApproved = false)
DB --> RestAPI : restaurantId
RestAPI --> HTTP : { restaurantId }
HTTP --> Dash : Tạo nhà hàng thành công
deactivate HTTP

Dash -> Dash : Chọn gói: Thường / Premium
Dash -> Dash : Shell.GoToAsync(\n"RestaurantPaymentPage?...")

deactivate Dash

activate Pay
Pay -> HTTP : POST /api/payments/register-restaurant\n{ restaurantId, amount, planType }
activate HTTP
HTTP -> PayAPI : RegisterRestaurantPayment(request)
PayAPI -> DB : Tạo Payment (Pending)
PayAPI --> HTTP : { paymentId, referenceCode }
HTTP --> Pay : Response
deactivate HTTP

Pay -> VQR : Tải hình QR
VQR --> Pay : QR Image
Pay --> Owner : Hiển thị QR chuyển khoản

Owner -> Owner : Chuyển khoản qua app ngân hàng

SePay -> PayAPI : POST /api/payments/webhook
PayAPI -> DB : Payment.Status = "Success"\nRestaurant.IsApproved = true
PayAPI --> SePay : { success: true }

Pay -> HTTP : GET /api/payments/check-restaurant/{id}
HTTP --> Pay : { isPaid: true }

Pay --> Owner : ✅ "Nhà hàng đã được kích hoạt!"
deactivate Pay

@enduml


' ================================================================


@startuml Sequence_07_AddDish
skinparam sequence {
    ArrowColor #00695C
    ParticipantBackgroundColor #E0F2F1
    ParticipantBorderColor #00695C
}

title Sơ đồ Sequence 7: Thêm món ăn + Thuyết minh

actor "Chủ nhà hàng" as Owner
participant "AddDishPage\n(MAUI)" as Page
participant "HttpClient" as HTTP
participant "DishesController\n(API)" as API
database "SQL Server" as DB

Owner -> Page : Nhập tên món, chọn ảnh,\nghi âm thuyết minh,\nchọn ngôn ngữ
activate Page

Page -> Page : Kiểm tra dữ liệu nhập

Page -> HTTP : POST /api/dishes\n(multipart/form-data)\n{ name, image, audioFile,\nlanguageId, textContent }
activate HTTP

HTTP -> API : Create(form)
activate API

API -> DB : Kiểm tra quyền sở hữu\nnhà hàng
DB --> API : Restaurant (owner match)

API -> DB : Kiểm tra giới hạn\nmón ăn (thường ≤ 8)

alt Chưa đạt giới hạn
    API -> API : Lưu ảnh vào wwwroot/images
    API -> DB : Thêm Dish mới
    DB --> API : DishId

    alt Có audio + languageId
        API -> API : Lưu audio vào wwwroot/audios
        API -> DB : Thêm Narration\n{ dishId, languageId, audioUrl }
    end

    API --> HTTP : 200 OK { dishId }
else Đã đạt giới hạn 8 món (Không Premium)
    API --> HTTP : 400 "Nâng cấp Premium\nđể thêm không giới hạn"
end
deactivate API

HTTP --> Page : Response
deactivate HTTP

alt Thành công
    Page --> Owner : DisplayAlert("Thêm món thành công!")
    Page -> Page : Shell.GoToAsync("..")
else Thất bại
    Page --> Owner : DisplayAlert("Lỗi", message)
end
deactivate Page

@enduml


