@startuml Sequence_01_Login
skinparam sequence {
    ArrowColor #1565C0
    LifeLineBorderColor #333
    ParticipantBackgroundColor #E3F2FD
    ParticipantBorderColor #1565C0
}

title Sơ đồ Sequence 1: Đăng nhập ứng dụng (App Login)

actor "Người dùng" as User
participant "LoginPage\n(MAUI)" as LP
participant "AuthService" as Auth
participant "HttpClient" as HTTP
participant "UsersController\n(API)" as API
database "SQL Server" as DB

User -> LP : Nhập Email + Mật khẩu
activate LP

LP -> Auth : LoginAsync(email, password)
activate Auth

Auth -> HTTP : POST /api/users/app-login
activate HTTP

HTTP -> API : AppLogin(request)
activate API

API -> DB : Tìm User theo Email
activate DB
DB --> API : Trả về User
deactivate DB

alt Mật khẩu đúng & Tài khoản Active
    API -> API : BCrypt.Verify(password, hash)
    API -> API : GenerateJwtToken(user)
    API --> HTTP : 200 OK { token, role, fullName, hasRestaurant }
else Sai mật khẩu
    API --> HTTP : 401 "Sai email hoặc mật khẩu"
else Tài khoản bị khóa
    API --> HTTP : 401 "Tài khoản đã bị khóa"
end
deactivate API

HTTP --> Auth : Response
deactivate HTTP

Auth -> Auth : SecureStorage.SetAsync("auth_token", token)
Auth --> LP : Kết quả đăng nhập
deactivate Auth

alt Đăng nhập thành công & Role = "Restaurant"
    LP -> LP : Shell.GoToAsync("RestaurantDashboardPage")
else Đăng nhập thành công & Role = "User"
    LP -> LP : Shell.GoToAsync("CustomerHomePage")
else Thất bại
    LP -> User : DisplayAlert("Lỗi", message)
end
deactivate LP

@enduml


' ================================================================


@startuml Sequence_02_Register
skinparam sequence {
    ArrowColor #2E7D32
    ParticipantBackgroundColor #E8F5E9
    ParticipantBorderColor #2E7D32
}

title Sơ đồ Sequence 2: Đăng ký tài khoản mới

actor "Người dùng" as User
participant "RegisterPage\n(MAUI)" as RP
participant "HttpClient" as HTTP
participant "UsersController\n(API)" as API
database "SQL Server" as DB

User -> RP : Nhập FullName, Email,\nPassword, chọn Role
activate RP

RP -> RP : Kiểm tra dữ liệu nhập

RP -> HTTP : POST /api/users/register\n{ email, password, fullName, role }
activate HTTP

HTTP -> API : Register(request)
activate API

API -> DB : Kiểm tra Email đã tồn tại?
activate DB
DB --> API : Kết quả
deactivate DB

alt Email chưa tồn tại
    API -> API : BCrypt.HashPassword(password)
    API -> DB : Thêm User mới
    activate DB
    DB --> API : Lưu thành công
    deactivate DB
    API -> API : GenerateJwtToken(user)
    API --> HTTP : 200 OK { token, role, fullName }
else Email đã tồn tại
    API --> HTTP : 400 "Email đã tồn tại"
end
deactivate API

HTTP --> RP : Response
deactivate HTTP

alt Đăng ký thành công
    RP -> RP : SecureStorage.SetAsync("auth_token", token)
    RP -> RP : Shell.GoToAsync("CustomerHomePage")
else Thất bại
    RP -> User : DisplayAlert("Lỗi", message)
end
deactivate RP

@enduml


' ================================================================


@startuml Sequence_03_ViewRestaurant
skinparam sequence {
    ArrowColor #E65100
    ParticipantBackgroundColor #FFF3E0
    ParticipantBorderColor #E65100
}

title Sơ đồ Sequence 3: Xem danh sách & chi tiết nhà hàng

actor "Người dùng" as User
participant "CustomerHomePage\n(MAUI)" as Home
participant "RestaurantService" as RS
participant "TranslationService" as TS
participant "LanguageService" as LS
participant "HttpClient" as HTTP
participant "RestaurantsController\n(API)" as API
database "SQL Server" as DB

User -> Home : Mở trang chủ
activate Home

Home -> RS : GetRestaurantsAsync()
activate RS

RS -> HTTP : GET /api/restaurants
activate HTTP

HTTP -> API : GetRestaurants()
activate API

API -> DB : Lấy danh sách nhà hàng\n(IsApproved = true)
activate DB
DB --> API : List<Restaurant> + Narrations
deactivate DB

API --> HTTP : 200 OK [RestaurantDto]
deactivate API

HTTP --> RS : List<RestaurantDto>
deactivate HTTP

RS --> Home : Danh sách nhà hàng
deactivate RS

Home -> LS : GetCurrentLanguage()
LS --> Home : languageCode (vd: "en")

alt Ngôn ngữ khác tiếng Việt
    Home -> TS : TranslateRestaurantsAsync(list, langCode)
    activate TS
    TS -> TS : Kiểm tra cache\n(ConcurrentDictionary)
    TS --> Home : Danh sách đã dịch
    deactivate TS
end

Home -> Home : Hiển thị lên CollectionView
Home --> User : Danh sách nhà hàng

User -> Home : Chọn nhà hàng
Home -> Home : Shell.GoToAsync(\n"RestaurantDetailPage?id=X")

deactivate Home

@enduml


