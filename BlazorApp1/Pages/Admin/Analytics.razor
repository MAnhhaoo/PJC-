@page "/admin/analytics"
@layout BlazorApp1.Shared.AdminLayout
@using MudBlazor
@using System.Text.Json
@inject HttpClient Http
@inject Blazored.LocalStorage.ILocalStorageService localStorage
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime
@implements IAsyncDisposable

<MudText Typo="Typo.h4" Class="mb-4">📊 Báo cáo & Analytics</MudText>

<!-- Period Filter -->
<MudPaper Class="pa-3 mb-4" Elevation="1">
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
        <MudSelect T="int" Label="Khoảng thời gian" @bind-Value="_selectedDays" Variant="Variant.Outlined" Dense="true" Style="max-width:200px;">
            <MudSelectItem Value="7">7 ngày qua</MudSelectItem>
            <MudSelectItem Value="14">14 ngày qua</MudSelectItem>
            <MudSelectItem Value="30">30 ngày qua</MudSelectItem>
            <MudSelectItem Value="90">90 ngày qua</MudSelectItem>
            <MudSelectItem Value="365">1 năm qua</MudSelectItem>
        </MudSelect>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Refresh"
                   OnClick="LoadAllData">Cập nhật</MudButton>
    </MudStack>
</MudPaper>

<!-- Overview Cards -->
<MudGrid Class="mb-4">
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="2">
            <MudIcon Icon="@Icons.Material.Filled.PlayCircle" Color="Color.Primary" Size="Size.Large" />
            <MudText Typo="Typo.h4" Class="mt-2">@_overview.TotalPlays</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Lượt phát thuyết minh</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="2">
            <MudIcon Icon="@Icons.Material.Filled.People" Color="Color.Success" Size="Size.Large" />
            <MudText Typo="Typo.h4" Class="mt-2">@_overview.UniqueVisitors</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Khách riêng biệt</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="2">
            <MudIcon Icon="@Icons.Material.Filled.Route" Color="Color.Warning" Size="Size.Large" />
            <MudText Typo="Typo.h4" Class="mt-2">@_overview.TotalSessions</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Phiên tour đã đi</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="2">
            <MudIcon Icon="@Icons.Material.Filled.Place" Color="Color.Error" Size="Size.Large" />
            <MudText Typo="Typo.h4" Class="mt-2">@_overview.TotalPOIsVisited</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Điểm POI đã ghé</MudText>
        </MudPaper>
    </MudItem>
</MudGrid>

<!-- Daily Plays Chart -->
@if (_overview.DailyLabels.Length > 0)
{
    <MudPaper Class="pa-4 mb-4" Elevation="2">
        <MudText Typo="Typo.h6" Class="mb-3">📈 Lượt phát theo ngày</MudText>
        <MudChart ChartType="ChartType.Line" ChartSeries="@_dailySeries" XAxisLabels="@_overview.DailyLabels"
                  Width="100%" Height="300px" ChartOptions="@_chartOptions" />
    </MudPaper>
}

<!-- Tabs: Heatmap / Top POIs / Journeys -->
<MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4"
         ActivePanelIndexChanged="OnTabChanged">

    <!-- TAB 1: Heatmap -->
    <MudTabPanel Text="🗺️ Heatmap mật độ khách" Icon="@Icons.Material.Filled.Map">
        <MudText Typo="Typo.body2" Class="mb-2" Color="Color.Secondary">
            Bản đồ nhiệt hiển thị mật độ khách du lịch tại các điểm POI trong @_selectedDays ngày qua.
            Các pin màu thể hiện mức độ lượt ghé (xanh = thấp → đỏ = cao).
        </MudText>

        <!-- Threshold Config -->
        <MudExpansionPanels Class="mb-3">
            <MudExpansionPanel Text="⚙️ Cài đặt ngưỡng màu heatmap" Dense="true">
                <MudGrid>
                    @for (int i = 0; i < _heatmapThresholds.Count; i++)
                    {
                        var idx = i;
                        <MudItem xs="12" sm="6" md="4">
                            <MudPaper Class="pa-2" Elevation="0" Style="@($"border-left: 4px solid {_heatmapThresholds[idx].Color}")">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                    <MudNumericField T="int" Label="Từ lượt ghé" @bind-Value="_heatmapThresholds[idx].Min"
                                                     Variant="Variant.Outlined" Dense="true" Style="max-width:100px;" />
                                    <MudTextField T="string" Label="Tên" @bind-Value="_heatmapThresholds[idx].Label"
                                                  Variant="Variant.Outlined" Dense="true" Style="max-width:120px;" />
                                    <MudTextField T="string" Label="Màu" @bind-Value="_heatmapThresholds[idx].Color"
                                                  Variant="Variant.Outlined" Dense="true" Style="max-width:100px;" />
                                    <div style="width:24px;height:24px;border-radius:50%;background:@(_heatmapThresholds[idx].Color);border:2px solid #ccc;"></div>
                                </MudStack>
                            </MudPaper>
                        </MudItem>
                    }
                </MudGrid>
                <MudStack Row="true" Class="mt-2" Spacing="2">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                               OnClick="SaveHeatmapConfig" StartIcon="@Icons.Material.Filled.Save">Lưu cài đặt</MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small"
                               OnClick="AddThreshold" StartIcon="@Icons.Material.Filled.Add">Thêm mức</MudButton>
                    @if (_heatmapThresholds.Count > 2)
                    {
                        <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                                   OnClick="RemoveLastThreshold" StartIcon="@Icons.Material.Filled.Remove">Xóa mức cuối</MudButton>
                    }
                </MudStack>
            </MudExpansionPanel>
        </MudExpansionPanels>

        <div id="analyticsHeatmap" style="height:500px; width:100%; border-radius:8px; border:1px solid #e0e0e0;"></div>

        @if (_heatmapData != null && _heatmapData.Count > 0)
        {
            <MudTable Items="@_heatmapData" Dense="true" Hover="true" Class="mt-3" Elevation="0">
                <HeaderContent>
                    <MudTh>Nhà hàng / Điểm</MudTh>
                    <MudTh>Lượt ghé</MudTh>
                    <MudTh>Mức độ</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.Name</MudTd>
                    <MudTd>
                        <MudChip T="string" Color="Color.Primary" Size="Size.Small">@context.Count</MudChip>
                    </MudTd>
                    <MudTd>
                        @{
                            var thresholdColor = GetThresholdColor(context.Count);
                            var thresholdLabel = GetThresholdLabel(context.Count);
                        }
                        <MudChip T="string" Size="Size.Small" Style="@($"background-color:{thresholdColor};color:white")">@thresholdLabel</MudChip>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
    </MudTabPanel>

    <!-- TAB 2: Top POIs -->
    <MudTabPanel Text="🏆 POI nghe nhiều nhất" Icon="@Icons.Material.Filled.EmojiEvents">
        <MudText Typo="Typo.body2" Class="mb-3" Color="Color.Secondary">
            Top điểm POI được nghe thuyết minh nhiều nhất trong @_selectedDays ngày qua.
        </MudText>

        @if (_topPOIs != null && _topPOIs.Count > 0)
        {
            <MudChart ChartType="ChartType.Bar" ChartSeries="@_topPOISeries" XAxisLabels="@_topPOILabels"
                      Width="100%" Height="350px" ChartOptions="@_chartOptions" />

            <MudTable Items="@_topPOIs" Dense="true" Hover="true" Class="mt-3" Elevation="0">
                <HeaderContent>
                    <MudTh>#</MudTh>
                    <MudTh>Nhà hàng / Điểm</MudTh>
                    <MudTh>Địa chỉ</MudTh>
                    <MudTh>Lượt phát</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>
                        @{
                            var rank = _topPOIs.IndexOf(context) + 1;
                            var medal = rank switch { 1 => "🥇", 2 => "🥈", 3 => "🥉", _ => rank.ToString() };
                        }
                        @medal
                    </MudTd>
                    <MudTd><strong>@context.Name</strong></MudTd>
                    <MudTd>@context.Address</MudTd>
                    <MudTd>
                        <MudChip T="string" Color="Color.Success" Size="Size.Small">@context.PlayCount lượt</MudChip>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
        else
        {
            <MudAlert Severity="Severity.Info">Chưa có dữ liệu phát thuyết minh trong khoảng thời gian này.</MudAlert>
        }
    </MudTabPanel>

    <!-- TAB 3: Journeys -->
    <MudTabPanel Text="🚶 Hành trình khách vãng lai" Icon="@Icons.Material.Filled.Timeline">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3" Class="mb-3">
            <MudSelect T="int" Label="Lọc theo Tour" @bind-Value="_journeyTourFilter" Variant="Variant.Outlined" Dense="true" Style="max-width:300px;">
                <MudSelectItem Value="0">Tất cả tour</MudSelectItem>
                @if (_tourList != null)
                {
                    @foreach (var t in _tourList)
                    {
                        <MudSelectItem Value="@t.TourId">@t.Name</MudSelectItem>
                    }
                }
            </MudSelect>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="LoadJourneys"
                       StartIcon="@Icons.Material.Filled.Search" Size="Size.Small">Xem hành trình</MudButton>
        </MudStack>

        <div id="analyticsJourneyMap" style="height:500px; width:100%; border-radius:8px; border:1px solid #e0e0e0;"></div>

        @if (_journeys != null && _journeys.Count > 0)
        {
            <MudTable Items="@_journeys" Dense="true" Hover="true" Class="mt-3" Elevation="0">
                <HeaderContent>
                    <MudTh>Session</MudTh>
                    <MudTh>Tour</MudTh>
                    <MudTh>Khách ẩn danh</MudTh>
                    <MudTh>Điểm GPS</MudTh>
                    <MudTh>Bắt đầu</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd><code>@context.SessionId[..Math.Min(8, context.SessionId.Length)]...</code></MudTd>
                    <MudTd>@context.TourName</MudTd>
                    <MudTd>
                        <MudChip T="string" Color="Color.Default" Size="Size.Small" Icon="@Icons.Material.Filled.VisibilityOff">@context.GuestLabel</MudChip>
                    </MudTd>
                    <MudTd>@context.PointCount</MudTd>
                    <MudTd>@context.StartTime.ToString("dd/MM/yyyy HH:mm")</MudTd>
                </RowTemplate>
            </MudTable>
        }
        else
        {
            <MudAlert Severity="Severity.Info">Chưa có dữ liệu hành trình trong khoảng thời gian này.</MudAlert>
        }
    </MudTabPanel>

    <!-- TAB 4: Live Visitors Heatmap -->
    <MudTabPanel Text="📍 Khách hiện tại (Real-time)" Icon="@Icons.Material.Filled.MyLocation">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3" Class="mb-3">
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Bản đồ hiển thị vị trí khách đang hoạt động trong 1 phút gần nhất.
            </MudText>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                       OnClick="RefreshLiveVisitors" StartIcon="@Icons.Material.Filled.Refresh">Làm mới</MudButton>
        </MudStack>

        <!-- Live stats cards -->
        <MudGrid Class="mb-3">
            <MudItem xs="12" sm="4">
                <MudPaper Class="pa-3 d-flex flex-column align-center" Elevation="1">
                    <MudIcon Icon="@Icons.Material.Filled.People" Color="Color.Primary" />
                    <MudText Typo="Typo.h5">@_liveTotal</MudText>
                    <MudText Typo="Typo.caption">Tổng đang online</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudPaper Class="pa-3 d-flex flex-column align-center" Elevation="1">
                    <MudIcon Icon="@Icons.Material.Filled.Person" Color="Color.Success" />
                    <MudText Typo="Typo.h5">@_liveRegistered</MudText>
                    <MudText Typo="Typo.caption">Đã đăng ký</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudPaper Class="pa-3 d-flex flex-column align-center" Elevation="1">
                    <MudIcon Icon="@Icons.Material.Filled.VisibilityOff" Color="Color.Default" />
                    <MudText Typo="Typo.h5">@_liveGuest</MudText>
                    <MudText Typo="Typo.caption">Khách vãng lai</MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>

        <div id="liveVisitorsMap" style="height:500px; width:100%; border-radius:8px; border:1px solid #e0e0e0;"></div>

        @if (_livePerRestaurant != null && _livePerRestaurant.Count > 0)
        {
            <MudTable Items="@_livePerRestaurant" Dense="true" Hover="true" Class="mt-3" Elevation="0">
                <HeaderContent>
                    <MudTh>Nhà hàng / Điểm</MudTh>
                    <MudTh>Số khách hiện tại</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.Name</MudTd>
                    <MudTd>
                        <MudChip T="string" Color="Color.Primary" Size="Size.Small">@context.VisitorCount khách</MudChip>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }

            </MudTabPanel>

            <!-- TAB 5: Hourly Peak Analysis -->
            <MudTabPanel Text="⏰ Giờ cao điểm" Icon="@Icons.Material.Filled.Schedule">
                <MudText Typo="Typo.body2" Class="mb-3" Color="Color.Secondary">
                    Phân tích lượt phát thuyết minh theo từng khung giờ trong @_selectedDays ngày qua.
                </MudText>

                @if (_hourlyLabels.Length > 0)
                {
                    <!-- Peak Hours Summary Cards -->
                    <MudGrid Class="mb-4">
                        @for (int i = 0; i < _topPeakHours.Count; i++)
                        {
                            var peak = _topPeakHours[i];
                            var rankIcon = i == 0 ? "🥇" : i == 1 ? "🥈" : "🥉";
                            var cardColor = i == 0 ? "#FF6F00" : i == 1 ? "#F57C00" : "#FFB74D";
                            var textColor = i == 0 ? "white" : i == 1 ? "white" : "#333";
                            <MudItem xs="12" sm="4">
                                <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="3"
                                          Style="@($"background: linear-gradient(135deg, {cardColor}, {cardColor}dd); border-radius: 16px;")">
                                    <MudText Typo="Typo.h3" Style="@($"color:{textColor}")">@rankIcon</MudText>
                                    <MudText Typo="Typo.h4" Style="@($"color:{textColor}; font-weight:bold")">@peak.Hour</MudText>
                                    <MudText Typo="Typo.h5" Style="@($"color:{textColor}")">@peak.PlayCount lượt phát</MudText>
                                    <MudText Typo="Typo.caption" Style="@($"color:{textColor}; opacity:0.8")">
                                        @(i == 0 ? "Cao điểm nhất" : i == 1 ? "Cao điểm thứ 2" : "Cao điểm thứ 3")
                                    </MudText>
                                </MudPaper>
                            </MudItem>
                        }
                    </MudGrid>

                    <!-- Hourly Bar Chart -->
                    <MudPaper Class="pa-4 mb-4" Elevation="2" Style="border-radius: 12px;">
                        <MudText Typo="Typo.h6" Class="mb-3">📊 Biểu đồ phân bố theo giờ</MudText>
                        <MudChart ChartType="ChartType.Bar" ChartSeries="@_hourlySeries" XAxisLabels="@_hourlyLabels"
                                  Width="100%" Height="350px" ChartOptions="@_hourlyChartOptions" />
                    </MudPaper>

                    <!-- Hourly Data Table -->
                    <MudPaper Class="pa-4" Elevation="2" Style="border-radius: 12px;">
                        <MudText Typo="Typo.h6" Class="mb-3">📋 Chi tiết theo khung giờ</MudText>
                        <MudTable Items="@_hourlyTableData" Dense="true" Hover="true" Striped="true" Elevation="0">
                            <HeaderContent>
                                <MudTh>Khung giờ</MudTh>
                                <MudTh>Lượt phát</MudTh>
                                <MudTh>Mức độ</MudTh>
                                <MudTh>Biểu đồ</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd><strong>@context.Label</strong></MudTd>
                                <MudTd>@context.PlayCount</MudTd>
                                <MudTd>
                                    @{
                                        var level = context.PlayCount >= (_peakPlayCount * 0.8) ? "🔴 Cao điểm"
                                            : context.PlayCount >= (_peakPlayCount * 0.4) ? "🟡 Trung bình"
                                            : context.PlayCount > 0 ? "🟢 Thấp" : "⚪ Không có";
                                    }
                                    @level
                                </MudTd>
                                <MudTd Style="min-width:200px;">
                                    <MudProgressLinear Color="@(context.PlayCount >= (_peakPlayCount * 0.8) ? Color.Error : context.PlayCount >= (_peakPlayCount * 0.4) ? Color.Warning : Color.Success)"
                                                       Value="@((_peakPlayCount > 0) ? (int)(context.PlayCount * 100.0 / _peakPlayCount) : 0)" Style="height:12px; border-radius:6px;" />
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    </MudPaper>
                }
                else
                {
                    <MudAlert Severity="Severity.Info">Chưa có dữ liệu trong khoảng thời gian này. Bấm "Cập nhật" để tải dữ liệu.</MudAlert>
                }
            </MudTabPanel>
        </MudTabs>

@code {
    private int _selectedDays = 30;
    private bool _loading;
    private OverviewData _overview = new();
    private List<ChartSeries<double>> _dailySeries = new();
    private ChartOptions _chartOptions = new();

    // Heatmap
    private List<HeatmapItem>? _heatmapData;
    private List<HeatmapThreshold> _heatmapThresholds = new();

    // Top POIs
    private List<TopPOIItem>? _topPOIs;
    private List<ChartSeries<double>> _topPOISeries = new();
    private string[] _topPOILabels = Array.Empty<string>();

    // Journeys
    private List<JourneyItem>? _journeys;
    private List<TourSimple>? _tourList;
    private int _journeyTourFilter = 0;

    private bool _heatmapInited;
    private bool _journeyMapInited;
    private bool _liveMapInited;

    private int _activeTabIndex = 0;

    // Live visitors
    private int _liveTotal;
    private int _liveRegistered;
    private int _liveGuest;
    private List<LiveRestaurantItem>? _livePerRestaurant;

    // Hourly stats
    private string[] _hourlyLabels = Array.Empty<string>();
    private List<ChartSeries<double>> _hourlySeries = new();
    private string _peakHour = "";
    private int _peakPlayCount;
    private List<PeakHourItem> _topPeakHours = new();
    private ChartOptions _hourlyChartOptions = new();
    private List<HourlyTableItem> _hourlyTableData = new();

    private async void OnTabChanged(int index)
    {
        Console.WriteLine($"[Analytics] OnTabChanged: {index}, _heatmapInited={_heatmapInited}, _journeyMapInited={_journeyMapInited}");
        _activeTabIndex = index;
        if (index == 0)
        {
            await Task.Delay(300);
            _heatmapInited = false;
            await InitHeatmap();
        }
        else if (index == 2)
        {
            await Task.Delay(300);
            _journeyMapInited = false;
            await InitJourneyMap();
        }
        else if (index == 3)
        {
            await Task.Delay(300);
            _liveMapInited = false;
            await LoadLiveVisitors();
        }
        else if (index == 4)
        {
            await LoadHourlyStats();
        }
    }

    private bool _firstRenderDone;

    protected override async Task OnInitializedAsync()
    {
        await LoadHeatmapConfig();
        await LoadAllData();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _firstRenderDone = true;
            Console.WriteLine($"[Analytics] OnAfterRenderAsync firstRender, _heatmapData={_heatmapData?.Count}, _heatmapInited={_heatmapInited}");
            // If data already loaded before first render, init heatmap now
            if (_heatmapData != null && !_heatmapInited && _activeTabIndex == 0)
            {
                await Task.Delay(200);
                await InitHeatmap();
            }
        }
    }

    private async Task LoadAllData()
    {
        _loading = true;
        StateHasChanged();

        try
        {
            await LoadOverview();
            await LoadHeatmap();
            await LoadTopPOIs();
            await LoadTourList();
            await LoadJourneys();
        }
        catch (Exception ex)
        {
            Snackbar.Add("Lỗi tải dữ liệu: " + ex.Message, Severity.Error);
        }

        _loading = false;
        StateHasChanged();

        // Re-init or update heatmap after data reload if DOM is already rendered
        if (_firstRenderDone && _activeTabIndex == 0)
        {
            await Task.Delay(300);
            await InitHeatmap();
        }
    }

    private async Task LoadOverview()
    {
        try
        {
            var json = await Http.GetStringAsync($"api/analytics/overview?days={_selectedDays}");
            using var doc = JsonDocument.Parse(json);
            var root = doc.RootElement;

            _overview.TotalPlays = root.GetProperty("totalPlays").GetInt32();
            _overview.UniqueVisitors = root.GetProperty("uniqueVisitors").GetInt32();
            _overview.TotalSessions = root.GetProperty("totalSessions").GetInt32();
            _overview.TotalPOIsVisited = root.GetProperty("totalPOIsVisited").GetInt32();

            var daily = root.GetProperty("dailyPlays");
            var labels = new List<string>();
            var values = new List<double>();
            foreach (var item in daily.EnumerateArray())
            {
                labels.Add(item.GetProperty("date").GetString() ?? "");
                values.Add(item.GetProperty("count").GetInt32());
            }
            _overview.DailyLabels = labels.ToArray();
            _dailySeries = new List<ChartSeries<double>>
            {
                new ChartSeries<double> { Name = "Lượt phát", Data = values.ToArray() }
            };
        }
        catch { }
    }

    private async Task LoadHeatmap()
    {
        try
        {
            var json = await Http.GetStringAsync($"api/analytics/heatmap?days={_selectedDays}");
            _heatmapData = JsonSerializer.Deserialize<List<HeatmapItem>>(json,
                new JsonSerializerOptions { PropertyNameCaseInsensitive = true }) ?? new();
        }
        catch { _heatmapData = new(); }
    }

    private async Task LoadTopPOIs()
    {
        try
        {
            var json = await Http.GetStringAsync($"api/analytics/top-pois?days={_selectedDays}&top=10");
            _topPOIs = JsonSerializer.Deserialize<List<TopPOIItem>>(json,
                new JsonSerializerOptions { PropertyNameCaseInsensitive = true }) ?? new();

            _topPOILabels = _topPOIs.Select(p => p.Name.Length > 15 ? p.Name[..15] + "…" : p.Name).ToArray();
            _topPOISeries = new List<ChartSeries<double>>
            {
