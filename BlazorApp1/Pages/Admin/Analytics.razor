    private async Task LoadJourneys()
    {
        try
        {
            var url = $"api/analytics/journeys?days={_selectedDays}";
            if (_journeyTourFilter > 0)
                url += $"&tourId={_journeyTourFilter}";

            var json = await Http.GetStringAsync(url);
            _journeys = JsonSerializer.Deserialize<List<JourneyItem>>(json,
                new JsonSerializerOptions { PropertyNameCaseInsensitive = true }) ?? new();
        }
        catch { _journeys = new(); }

        StateHasChanged();

        // Only update map if it's already initialized (journey tab is visible)
        if (_journeyMapInited)
        {
            await ShowJourneysOnMap();
        }
    }

    private async Task InitHeatmap()
    {
        try
        {
            Console.WriteLine($"[Heatmap] InitHeatmap called, _heatmapInited={_heatmapInited}, data count={_heatmapData?.Count}");
            if (!_heatmapInited)
            {
                bool created = false;
                for (int i = 0; i < 15; i++)
                {
                    created = await JSRuntime.InvokeAsync<bool>("initAnalyticsHeatmap", "analyticsHeatmap");
                    if (created) break;
                    await Task.Delay(300);
                }
                if (!created) { Console.WriteLine("[Heatmap] Failed to create map after 15 retries"); return; }
                _heatmapInited = true;
                await Task.Delay(200);
            }

            if (_heatmapData != null && _heatmapData.Count > 0)
            {
                Console.WriteLine($"[Heatmap] Calling updateHeatmap with {_heatmapData.Count} items, first: lat={_heatmapData[0].Lat}, lng={_heatmapData[0].Lng}");
                var thresholdsJs = _heatmapThresholds.Select(t => new { min = t.Min, color = t.Color, label = t.Label }).ToArray();
                await JSRuntime.InvokeVoidAsync("updateHeatmap", (object)_heatmapData.Select(h => new
                {
                    lat = h.Lat,
                    lng = h.Lng,
                    name = h.Name,
                    count = h.Count
                }).ToArray(), (object)thresholdsJs);
            }
            else
            {
                Console.WriteLine($"[Heatmap] No data to show, _heatmapData is {(_heatmapData == null ? "null" : "empty")}");
            }
        }
        catch (Exception ex) { Console.WriteLine($"[Heatmap] Error: {ex}"); }
    }

    private async Task InitJourneyMap()
    {
        try
        {
            Console.WriteLine($"[Journey] InitJourneyMap called, _journeyMapInited={_journeyMapInited}");
            bool created = false;
            for (int i = 0; i < 15; i++)
            {
                created = await JSRuntime.InvokeAsync<bool>("initJourneyMap", "analyticsJourneyMap");
                if (created) break;
                await Task.Delay(300);
            }
            if (!created) { Console.WriteLine("[Journey] Failed to create map after 15 retries"); return; }
            _journeyMapInited = true;
            await Task.Delay(300);
            await ShowJourneysOnMap();
        }
        catch (Exception ex) { Console.WriteLine($"[Journey] InitJourneyMap error: {ex}"); }
    }

    private async Task ShowJourneysOnMap()
    {
        try
        {
            if (_journeys != null && _journeys.Count > 0)
            {
                Console.WriteLine($"[Journey] ShowJourneysOnMap: {_journeys.Count} sessions, first has {_journeys[0].Points?.Count} points");
                await JSRuntime.InvokeVoidAsync("showJourneys", (object)_journeys.Select(j => new
                {
                    sessionId = j.SessionId,
                    tourId = j.TourId,
                    tourName = j.TourName,
                    userId = j.UserId,
                    guestLabel = j.GuestLabel,
                    startTime = j.StartTime,
                    pointCount = j.PointCount,
                    points = j.Points?.Select(p => new { lat = p.Lat, lng = p.Lng, time = p.Time }).ToArray()
                }).ToArray());
            }
            else
            {
                Console.WriteLine($"[Journey] No journey data to show");
            }
        }
        catch (Exception ex) { Console.WriteLine($"[Journey] ShowJourneysOnMap error: {ex}"); }
    }

