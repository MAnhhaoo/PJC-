    private async Task LoadLiveVisitors()
    {
        try
        {
            var json = await Http.GetStringAsync("api/analytics/active-visitors");
            using var doc = JsonDocument.Parse(json);
            var root = doc.RootElement;

            _liveTotal = root.GetProperty("totalActive").GetInt32();
            _liveRegistered = root.GetProperty("registeredCount").GetInt32();
            _liveGuest = root.GetProperty("guestCount").GetInt32();

            var visitors = root.GetProperty("visitors");
            var perRestaurant = root.GetProperty("perRestaurant");

            _livePerRestaurant = new();
            foreach (var r in perRestaurant.EnumerateArray())
            {
                _livePerRestaurant.Add(new LiveRestaurantItem
                {
                    Name = r.GetProperty("name").GetString() ?? "",
                    VisitorCount = r.GetProperty("visitorCount").GetInt32(),
                    Latitude = r.GetProperty("latitude").GetDouble(),
                    Longitude = r.GetProperty("longitude").GetDouble()
                });
            }

            StateHasChanged();

            // Init map
            if (!_liveMapInited)
            {
                bool created = false;
                for (int i = 0; i < 15; i++)
                {
                    created = await JSRuntime.InvokeAsync<bool>("initLiveVisitorsMap", "liveVisitorsMap");
                    if (created) break;
                    await Task.Delay(300);
                }
                if (!created) return;
                _liveMapInited = true;
                await Task.Delay(200);
            }

            // Build visitor array for JS
            var visitorsArr = new List<object>();
            foreach (var v in visitors.EnumerateArray())
            {
                visitorsArr.Add(new
                {
                    type = v.GetProperty("type").GetString(),
                    label = v.GetProperty("label").GetString(),
                    lat = v.GetProperty("lat").GetDouble(),
                    lng = v.GetProperty("lng").GetDouble()
                });
            }

            var perRestArr = _livePerRestaurant.Select(r => new
            {
                name = r.Name,
                latitude = r.Latitude,
                longitude = r.Longitude,
                visitorCount = r.VisitorCount
            }).ToArray();

            var thresholdsJs = _heatmapThresholds.Select(t => new { min = t.Min, color = t.Color }).ToArray();
            await JSRuntime.InvokeVoidAsync("updateLiveVisitors", visitorsArr.ToArray(), perRestArr, thresholdsJs);
        }
        catch (Exception ex) { Console.WriteLine($"LoadLiveVisitors error: {ex.Message}"); }
    }

    private async Task RefreshLiveVisitors()
    {
        await LoadLiveVisitors();
    }

    private async Task LoadHourlyStats()
    {
        try
        {
            var json = await Http.GetStringAsync($"api/analytics/hourly-stats?days={_selectedDays}");
            using var doc = JsonDocument.Parse(json);
            var root = doc.RootElement;

            _peakHour = root.GetProperty("peakHour").GetString() ?? "";
            _peakPlayCount = root.GetProperty("peakPlayCount").GetInt32();

            _topPeakHours = new();
            if (root.TryGetProperty("topPeakHours", out var topPeaks))
            {
                foreach (var p in topPeaks.EnumerateArray())
                {
                    _topPeakHours.Add(new PeakHourItem
                    {
                        Hour = p.GetProperty("hour").GetString() ?? "",
                        PlayCount = p.GetProperty("playCount").GetInt32()
                    });
                }
            }

            var hourly = root.GetProperty("hourlyData");
            var labels = new List<string>();
            var values = new List<double>();
            foreach (var item in hourly.EnumerateArray())
            {
                labels.Add(item.GetProperty("label").GetString() ?? "");
                values.Add(item.GetProperty("playCount").GetInt32());
            }
            _hourlyLabels = labels.ToArray();
            _hourlySeries = new List<ChartSeries<double>>
            {
                new ChartSeries<double> { Name = "Lượt phát", Data = values.ToArray() }
            };

            _hourlyTableData = new();
            for (int i = 0; i < labels.Count; i++)
            {
                _hourlyTableData.Add(new HourlyTableItem { Label = labels[i], PlayCount = (int)values[i] });
            }

            StateHasChanged();
        }
        catch (Exception ex) { Console.WriteLine($"LoadHourlyStats error: {ex.Message}"); }
    }

    private async Task LoadHeatmapConfig()
    {
        try
        {
            var list = await Http.GetFromJsonAsync<List<HeatmapThreshold>>("api/analytics/heatmap-config");
            if (list != null && list.Count > 0)
                _heatmapThresholds = list;
            else
                _heatmapThresholds = new List<HeatmapThreshold>
                {
                    new() { Min = 0, Color = "#4CAF50", Label = "Ít" },
                    new() { Min = 5, Color = "#FF9800", Label = "Trung bình" },
                    new() { Min = 15, Color = "#F44336", Label = "Nhiều" }
                };
        }
        catch
        {
            _heatmapThresholds = new List<HeatmapThreshold>
            {
                new() { Min = 0, Color = "#4CAF50", Label = "Ít" },
                new() { Min = 5, Color = "#FF9800", Label = "Trung bình" },
                new() { Min = 15, Color = "#F44336", Label = "Nhiều" }
            };
        }
    }

    private async Task SaveHeatmapConfig()
    {
        try
        {
            var ordered = _heatmapThresholds.OrderBy(t => t.Min).ToList();
            _heatmapThresholds = ordered;
            await Http.PutAsJsonAsync("api/analytics/heatmap-config", _heatmapThresholds);
            _heatmapInited = false;
            await InitHeatmap();
        }
        catch (Exception ex) { Console.WriteLine($"SaveHeatmapConfig error: {ex.Message}"); }
    }

    private void AddThreshold()
    {
        var maxMin = _heatmapThresholds.Count > 0 ? _heatmapThresholds.Max(t => t.Min) : 0;
        _heatmapThresholds.Add(new HeatmapThreshold { Min = maxMin + 10, Color = "#9C27B0", Label = "Mới" });
    }

    private void RemoveLastThreshold()
    {
        if (_heatmapThresholds.Count > 2)
            _heatmapThresholds.RemoveAt(_heatmapThresholds.Count - 1);
    }

    private string GetThresholdColor(int count)
    {
        var ordered = _heatmapThresholds.OrderByDescending(t => t.Min).ToList();
        foreach (var t in ordered)
        {
            if (count >= t.Min) return t.Color;
        }
        return _heatmapThresholds.FirstOrDefault()?.Color ?? "#4CAF50";
    }

    private string GetThresholdLabel(int count)
    {
        var ordered = _heatmapThresholds.OrderByDescending(t => t.Min).ToList();
        foreach (var t in ordered)
        {
            if (count >= t.Min) return t.Label;
        }
        return _heatmapThresholds.FirstOrDefault()?.Label ?? "Ít";
    }

