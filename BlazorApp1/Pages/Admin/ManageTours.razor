@page "/admin/tours"
@layout BlazorApp1.Shared.AdminLayout
@using MudBlazor
@inject HttpClient Http
@inject Blazored.LocalStorage.ILocalStorageService localStorage
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IJSRuntime JSRuntime

<MudText Typo="Typo.h4" Class="mb-4">🗺️ Quản lý Tour du lịch</MudText>

<MudButton Variant="Variant.Filled" Color="Color.Success" StartIcon="@Icons.Material.Filled.Add"
           OnClick="OpenCreateDialog" Class="mb-4">
    Tạo Tour mới
</MudButton>

@if (_loading)
{
    <MudProgressCircular Indeterminate="true" />
}
else if (_tours == null || !_tours.Any())
{
    <MudAlert Severity="Severity.Info">Chưa có tour nào.</MudAlert>
}
else
{
    <MudTable Items="@_tours" Hover="true" Striped="true" Dense="true" Elevation="2">
        <HeaderContent>
            <MudTh>ID</MudTh>
            <MudTh>Tên Tour</MudTh>
            <MudTh>Mô tả</MudTh>
            <MudTh>Giá</MudTh>
            <MudTh>Số điểm</MudTh>
            <MudTh>Trạng thái</MudTh>
            <MudTh>Ngày tạo</MudTh>
            <MudTh>Hành động</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.TourId</MudTd>
            <MudTd><MudText Typo="Typo.body1"><b>@context.Name</b></MudText></MudTd>
            <MudTd>@(context.Description?.Length > 60 ? context.Description[..60] + "..." : context.Description)</MudTd>
            <MudTd>
                @if (context.Price > 0)
                {
                    <MudChip T="string" Color="Color.Warning" Size="Size.Small">@context.Price.ToString("N0")đ</MudChip>
                }
                else
                {
                    <MudChip T="string" Color="Color.Success" Size="Size.Small">Miễn phí</MudChip>
                }
            </MudTd>
            <MudTd>
                <MudChip T="string" Color="Color.Info" Size="Size.Small">@context.POIs.Count điểm</MudChip>
            </MudTd>
            <MudTd>
                @if (context.IsActive)
                {
                    <MudChip T="string" Color="Color.Success" Size="Size.Small">Hoạt động</MudChip>
                }
                else
                {
                    <MudChip T="string" Color="Color.Default" Size="Size.Small">Tạm ẩn</MudChip>
                }
            </MudTd>
            <MudTd>@context.CreatedAt.ToString("dd/MM/yyyy")</MudTd>
            <MudTd>
                <MudStack Row="true" Spacing="1">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small"
                                   OnClick="@(() => OpenEditDialog(context))" />
                    <MudIconButton Icon="@(context.IsActive ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                   Color="Color.Warning" Size="Size.Small"
                                   OnClick="@(() => ToggleTour(context))" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                   OnClick="@(() => DeleteTour(context))" />
                </MudStack>
            </MudTd>
        </RowTemplate>
        <ChildRowContent>
            @if (context.POIs.Any())
            {
                <MudTr>
                    <td colspan="8" style="padding: 12px 24px; background: #FAFAFA;">
                        <MudText Typo="Typo.subtitle2" Class="mb-2">📍 Lộ trình (@context.POIs.Count điểm):</MudText>
                        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Style="flex-wrap:wrap">
                            @foreach (var poi in context.POIs.OrderBy(p => p.OrderIndex))
                            {
                                <MudChip T="string" Color="Color.Primary" Size="Size.Small">
                                    @poi.OrderIndex. @poi.RestaurantName
                                </MudChip>
                                @if (poi != context.POIs.OrderBy(p => p.OrderIndex).Last())
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" Color="Color.Secondary" />
                                }
                            }
                        </MudStack>
                    </td>
                </MudTr>
            }
        </ChildRowContent>
    </MudTable>
}

@* ===== CREATE/EDIT DIALOG ===== *@
<MudDialog @bind-Visible="_dialogVisible" Options="@(new DialogOptions { MaxWidth = MaxWidth.Large, FullWidth = true })">
    <TitleContent>
        <MudText Typo="Typo.h6">@(_editingTour == null ? "Tạo Tour mới" : "Chỉnh sửa Tour")</MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_formName" Label="Tên Tour" Required="true" Class="mb-3" />
        <MudTextField @bind-Value="_formDescription" Label="Mô tả" Lines="3" Class="mb-3" />
        <MudNumericField @bind-Value="_formPrice" Label="Giá tour (đ)" Min="0" Format="N0" Class="mb-3"
                         Adornment="Adornment.End" AdornmentText="đ" HelperText="Nhập 0 = Miễn phí" />

        <MudText Typo="Typo.subtitle1" Class="mt-4 mb-2">📍 Chọn POI (nhà hàng) theo thứ tự:</MudText>

        @if (_allRestaurants == null)
        {
            <MudProgressCircular Indeterminate="true" Size="Size.Small" />
        }
        else
        {
            <MudStack Spacing="2">
                @for (int i = 0; i < _selectedPOIs.Count; i++)
                {
                    var idx = i;
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudChip T="string" Color="Color.Dark" Size="Size.Small">@(idx + 1)</MudChip>
                        <MudSelect T="int" Value="_selectedPOIs[idx]"
                                   ValueChanged="@(async (int val) => { _selectedPOIs[idx] = val; await UpdateMapPreview(); })"
                                   Label="Nhà hàng" Dense="true" Style="flex:1">
                            @foreach (var r in _allRestaurants)
                            {
                                <MudSelectItem T="int" Value="@r.RestaurantId">@r.Name (@r.Address)</MudSelectItem>
                            }
                        </MudSelect>
                        <MudIconButton Icon="@Icons.Material.Filled.ArrowUpward" Size="Size.Small"
                                       Disabled="@(idx == 0)" OnClick="@(async () => await MovePOIAsync(idx, -1))" />
                        <MudIconButton Icon="@Icons.Material.Filled.ArrowDownward" Size="Size.Small"
                                       Disabled="@(idx == _selectedPOIs.Count - 1)" OnClick="@(async () => await MovePOIAsync(idx, 1))" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                       OnClick="@(async () => { _selectedPOIs.RemoveAt(idx); await UpdateMapPreview(); })" />
                    </MudStack>
                }
            </MudStack>

            <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                       OnClick="@(() => _selectedPOIs.Add(0))" Class="mt-2" Size="Size.Small">
                Thêm điểm
            </MudButton>

            <MudStack Row="true" AlignItems="AlignItems.Center" Class="mt-4 mb-2">
                <MudText Typo="Typo.subtitle1">🗺️ Bản đồ lộ trình:</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Refresh" Size="Size.Small" Color="Color.Primary"
                               OnClick="RefreshMap" Title="Làm mới bản đồ" />
            </MudStack>
            <div id="tourMapContainer" style="height:350px;width:100%;border-radius:8px;border:1px solid #ddd;"></div>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseDialog">Hủy</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveTour" Disabled="@_saving">
            @if (_saving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
            Lưu
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<TourAdminDto> _tours = new();
    private List<RestaurantSimpleDto> _allRestaurants = new();
    private bool _loading = true;
    private bool _saving;
    private bool _needMapInit;

    // Dialog
    private bool _dialogVisible;
    private TourAdminDto? _editingTour;
    private string _formName = "";
    private string? _formDescription;
    private decimal _formPrice;
    private List<int> _selectedPOIs = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_needMapInit)
        {
            _needMapInit = false;
            await Task.Delay(250);
            await JSRuntime.InvokeVoidAsync("initTourMap", "tourMapContainer");
            await UpdateMapPreview();
        }
    }

    private async Task<string?> GetToken()
    {
        return await localStorage.GetItemAsync<string>("token");
    }

    private async Task LoadData()
    {
        _loading = true;
        try
        {
            var token = await GetToken();
            var request = new HttpRequestMessage(HttpMethod.Get, "api/tours/all");
            if (!string.IsNullOrEmpty(token))
                request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

            var response = await Http.SendAsync(request);
            if (response.IsSuccessStatusCode)
                _tours = await response.Content.ReadFromJsonAsync<List<TourAdminDto>>() ?? new();
        }
        catch (Exception ex)
        {
            Snackbar.Add("Lỗi: " + ex.Message, Severity.Error);
        }
        finally { _loading = false; }
    }

    private async Task LoadRestaurants()
    {
        if (_allRestaurants.Any()) return;
        try
        {
            var token = await GetToken();
            var request = new HttpRequestMessage(HttpMethod.Get, "api/restaurants/admin/all");
            if (!string.IsNullOrEmpty(token))
                request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

            var response = await Http.SendAsync(request);
            if (response.IsSuccessStatusCode)
                _allRestaurants = await response.Content.ReadFromJsonAsync<List<RestaurantSimpleDto>>() ?? new();
        }
        catch
        {
            // Fallback: try public endpoint
            _allRestaurants = await Http.GetFromJsonAsync<List<RestaurantSimpleDto>>("api/restaurants") ?? new();
        }
    }

    private async Task OpenCreateDialog()
    {
        _editingTour = null;
        _formName = "";
        _formDescription = "";
        _formPrice = 0;
        _selectedPOIs = new List<int> { 0 };
        await LoadRestaurants();
        _dialogVisible = true;
        _needMapInit = true;
        StateHasChanged();
        await Task.Delay(500);
        try
        {
            await JSRuntime.InvokeVoidAsync("initTourMap", "tourMapContainer");
            await UpdateMapPreview();
        }
        catch { }
    }

    private async Task OpenEditDialog(TourAdminDto tour)
    {
        _editingTour = tour;
        _formName = tour.Name;
        _formDescription = tour.Description;
        _formPrice = tour.Price;
        _selectedPOIs = tour.POIs.OrderBy(p => p.OrderIndex).Select(p => p.RestaurantId).ToList();
        if (!_selectedPOIs.Any()) _selectedPOIs.Add(0);
        await LoadRestaurants();
        _dialogVisible = true;
        _needMapInit = true;
        StateHasChanged();
        await Task.Delay(500);
        try
        {
            await JSRuntime.InvokeVoidAsync("initTourMap", "tourMapContainer");
            await UpdateMapPreview();
        }
        catch { }
    }

    private async Task MovePOIAsync(int index, int direction)
    {
        var newIndex = index + direction;
        if (newIndex < 0 || newIndex >= _selectedPOIs.Count) return;
        (_selectedPOIs[index], _selectedPOIs[newIndex]) = (_selectedPOIs[newIndex], _selectedPOIs[index]);
        await UpdateMapPreview();
    }

    private async Task CloseDialog()
    {
        _dialogVisible = false;
        try { await JSRuntime.InvokeVoidAsync("destroyTourMap"); } catch { }
    }

    private async Task UpdateMapPreview()
    {
        if (_allRestaurants == null) return;
        var markers = new List<object>();
        foreach (var id in _selectedPOIs.Where(id => id > 0))
        {
            var r = _allRestaurants.FirstOrDefault(x => x.RestaurantId == id);
            if (r != null && IsValidCoordinate(r.Latitude, r.Longitude))
                markers.Add(new { lat = r.Latitude, lng = r.Longitude, name = r.Name ?? "", address = r.Address ?? "" });
        }
        try { await JSRuntime.InvokeVoidAsync("updateTourMapMarkers", markers); } catch { }
    }

    private static bool IsValidCoordinate(double lat, double lng)
    {
        return lat >= -90 && lat <= 90 && lng >= -180 && lng <= 180
            && (Math.Abs(lat) > 0.0001 || Math.Abs(lng) > 0.0001);
    }

    private async Task RefreshMap()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("initTourMap", "tourMapContainer");
            await Task.Delay(400);
            await UpdateMapPreview();
        }
        catch { }
    }

    private async Task SaveTour()
    {
        if (string.IsNullOrWhiteSpace(_formName))
        {
            Snackbar.Add("Vui lòng nhập tên tour", Severity.Warning);
            return;
        }

        var validPOIs = _selectedPOIs.Where(id => id > 0).ToList();
        if (!validPOIs.Any())
        {
            Snackbar.Add("Vui lòng chọn ít nhất 1 điểm", Severity.Warning);
            return;
        }

        _saving = true;
        try
        {
            var token = await GetToken();
            var body = new
            {
                Name = _formName,
                Description = _formDescription,
                Price = _formPrice,
                POIs = validPOIs.Select((id, i) => new { RestaurantId = id, OrderIndex = i + 1 }).ToList()
            };

            HttpRequestMessage request;
            if (_editingTour == null)
            {
                request = new HttpRequestMessage(HttpMethod.Put, "api/tours");
                request.Method = HttpMethod.Post;
            }
            else
            {
                request = new HttpRequestMessage(HttpMethod.Put, $"api/tours/{_editingTour.TourId}");
            }

            request.Content = JsonContent.Create(body);
            if (!string.IsNullOrEmpty(token))
                request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

            var response = await Http.SendAsync(request);
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add(_editingTour == null ? "Đã tạo tour!" : "Đã cập nhật tour!", Severity.Success);
                await CloseDialog();
                await LoadData();
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Snackbar.Add("Lỗi: " + error, Severity.Error);
            }
        }
        catch (Exception ex) { Snackbar.Add("Lỗi: " + ex.Message, Severity.Error); }
        finally { _saving = false; }
    }

    private async Task ToggleTour(TourAdminDto tour)
    {
        try
        {
            var token = await GetToken();
            var request = new HttpRequestMessage(HttpMethod.Patch, $"api/tours/{tour.TourId}/toggle");
            if (!string.IsNullOrEmpty(token))
                request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

            var response = await Http.SendAsync(request);
            if (response.IsSuccessStatusCode)
            {
                tour.IsActive = !tour.IsActive;
                Snackbar.Add(tour.IsActive ? "Đã kích hoạt" : "Đã ẩn tour", Severity.Success);
            }
        }
        catch (Exception ex) { Snackbar.Add("Lỗi: " + ex.Message, Severity.Error); }
    }

    private async Task DeleteTour(TourAdminDto tour)
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", $"Bạn có chắc muốn xóa tour \"{tour.Name}\"?");
        if (!confirmed) return;

        try
        {
            var token = await GetToken();
            var request = new HttpRequestMessage(HttpMethod.Delete, $"api/tours/{tour.TourId}");
            if (!string.IsNullOrEmpty(token))
                request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

            var response = await Http.SendAsync(request);
            if (response.IsSuccessStatusCode)
            {
                _tours.Remove(tour);
                Snackbar.Add("Đã xóa tour", Severity.Success);
            }
        }
        catch (Exception ex) { Snackbar.Add("Lỗi: " + ex.Message, Severity.Error); }
    }

    // ===== DTOs =====
    class TourAdminDto
    {
        public int TourId { get; set; }
        public string Name { get; set; } = "";
        public string? Description { get; set; }
        public string? Image { get; set; }
        public bool IsActive { get; set; }
        public decimal Price { get; set; }
        public DateTime CreatedAt { get; set; }
        public List<TourPOIAdminDto> POIs { get; set; } = new();
    }

    class TourPOIAdminDto
    {
        public int TourPOIId { get; set; }
        public int RestaurantId { get; set; }
        public string RestaurantName { get; set; } = "";
        public string? RestaurantAddress { get; set; }
        public int OrderIndex { get; set; }
    }

    class RestaurantSimpleDto
    {
        public int RestaurantId { get; set; }
        public string? Name { get; set; }
        public string? Address { get; set; }
        public double Latitude { get; set; }
        public double Longitude { get; set; }
    }
}
