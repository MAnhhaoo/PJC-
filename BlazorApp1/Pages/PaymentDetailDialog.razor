@using MudBlazor
@inject ApiService Api

<MudDialog MaxWidth="MaxWidth.Small" FullWidth="true">

    <DialogContent>

        <!-- HEADER -->
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
            <MudIcon Icon="@Icons.Material.Filled.ReceiptLong"
                     Color="Color.Primary"
                     Size="Size.Medium" />
            <MudText Typo="Typo.h6">Chi tiết thanh toán</MudText>
        </MudStack>

        <MudDivider Class="mb-4" />

        <!-- CONTENT -->
        <MudGrid>

            <MudItem xs="12" md="6">
                <MudText Typo="Typo.caption">User</MudText>
                <MudText Typo="Typo.body1">@Payment.UserName</MudText>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudText Typo="Typo.caption">Email</MudText>
                <MudText Typo="Typo.body1">@Payment.Email</MudText>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudText Typo="Typo.caption">Loại thanh toán</MudText>
                <MudChip T="string" Size="Size.Small" Variant="Variant.Text"
                         Color="@GetTypeColor(Payment.PaymentType)">
                    @Payment.PaymentType
                </MudChip>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudText Typo="Typo.caption">Số tiền</MudText>
                <MudText Typo="Typo.h6" Color="Color.Success">
                    @Payment.Amount.ToString("N0") đ
                </MudText>
            </MudItem>

            @if (!string.IsNullOrEmpty(Payment.TourName))
            {
                <MudItem xs="12" md="6">
                    <MudText Typo="Typo.caption">Tour</MudText>
                    <MudText Typo="Typo.body1">🗺️ @Payment.TourName</MudText>
                </MudItem>
            }

            @if (!string.IsNullOrEmpty(Payment.RestaurantName))
            {
                <MudItem xs="12" md="6">
                    <MudText Typo="Typo.caption">Nhà hàng</MudText>
                    <MudText Typo="Typo.body1">🍽️ @Payment.RestaurantName</MudText>
                </MudItem>
            }

            <MudItem xs="12" md="6">
                <MudText Typo="Typo.caption">Trạng thái</MudText>
                <MudChip T="string"
                         Color="@GetStatusColor(Payment.Status)"
                         Variant="Variant.Filled"
                         Size="Size.Small">
                    @Payment.Status
                </MudChip>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudText Typo="Typo.caption">Phương thức</MudText>
                <MudText Typo="Typo.body1">
                    @(Payment.PaymentMethod ?? "N/A")
                </MudText>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudText Typo="Typo.caption">Mã chuyển khoản</MudText>
                <MudText Typo="Typo.body1" Style="font-family:monospace; color:#E65100">
                    @(Payment.TransactionId ?? "N/A")
                </MudText>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudText Typo="Typo.caption">Ngày thanh toán</MudText>
                <MudText Typo="Typo.body1">
                    @Payment.PaymentDate.ToString("dd/MM/yyyy HH:mm")
                </MudText>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudText Typo="Typo.caption">Ngày hết hạn</MudText>
                <MudText Typo="Typo.body1">
                    @(Payment.ExpireDate?.ToString("dd/MM/yyyy") ?? "N/A")
                </MudText>
            </MudItem>

        </MudGrid>

    </DialogContent>

    <DialogActions>
        @if (Payment.Status == "Pending")
        {
            <MudButton Variant="Variant.Filled"
                       Color="Color.Success"
                       OnClick="ConfirmPayment">
                ✅ Duyệt thanh toán
            </MudButton>
        }
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   OnClick="Close">
            Đóng
        </MudButton>
    </DialogActions>

</MudDialog>

@code {

    [CascadingParameter]
    public IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public AdminPayments.PaymentViewModel Payment { get; set; } = default!;

    private async Task ConfirmPayment()
    {
        var response = await Api.PostAsync($"api/payments/confirm/{Payment.PaymentId}", new { });
        if (response.IsSuccessStatusCode)
        {
            Payment.Status = "Success";
            StateHasChanged();
        }
    }

    void Close()
    {
        MudDialog.Close();
    }

    private Color GetStatusColor(string status)
    {
        return status switch
        {
            "Success" => Color.Success,
            "Pending" => Color.Warning,
            "Failed" => Color.Error,
            _ => Color.Default
        };
    }

    private Color GetTypeColor(string type)
    {
        return type switch
        {
            "TourPurchase" => Color.Info,
            "UserUpgrade" => Color.Secondary,
            "RestaurantRegistration" => Color.Tertiary,
            "RestaurantPremium" => Color.Warning,
            _ => Color.Default
        };
    }
}
